{# Reusable share button macro. Pages call {{ share_button(url, title) }}
   anywhere they want to render a Share affordance. The global script
   below wires up navigator.share / clipboard fallback. #}
{% macro share_button(url, title, label='Share') -%}
<button type="button" class="share-btn"
        data-share-url="{{ url }}"
        data-share-title="{{ title|e }}"
        aria-label="Share this page">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
    <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
  </svg>
  <span class="share-btn-label">{{ label }}</span>
</button>
{%- endmacro %}

{% block content %}{% endblock %}

<div class="notify-modal-overlay" id="notify-modal-overlay">
  <div class="notify-modal">
    <button type="button" class="notify-modal-close" id="notify-modal-close" aria-label="Close">&times;</button>
    <h3 id="notify-modal-heading"></h3>
    <p id="notify-modal-subtext"></p>
    <form id="notify-modal-form" class="notify-modal-fields">
      <input type="text" name="name" placeholder="Name (optional)" autocomplete="name">
      <input type="email" name="email" placeholder="you@company.com" required autocomplete="email">
      <button type="submit" class="notify-modal-submit">Notify Me</button>
    </form>
    <div class="notify-modal-fine">Free. Unsubscribe anytime. No spam.</div>
  </div>
</div>

<div class="feedback-widget" data-feedback-widget>
  <button type="button" class="feedback-pill" data-feedback-open aria-haspopup="dialog" aria-controls="feedback-panel">
    Share Your Ideas
  </button>
  <section class="feedback-panel" id="feedback-panel" data-feedback-panel role="dialog" aria-modal="false" aria-labelledby="feedback-title">
    <button type="button" class="feedback-close" data-feedback-close aria-label="Close feedback form">&times;</button>
    <h2 id="feedback-title">Help us build what you need.</h2>
    <p>Tell us what tools, data, checklists, or workflow would make your experience better.</p>
    <form class="feedback-form" data-feedback-form>
      <label>
        Your idea
        <textarea name="message" maxlength="2000" required placeholder="What would make your work easier?"></textarea>
      </label>
      <label>
        (Optional) Email, if you want us to follow up.
        <input type="email" name="email" autocomplete="email" placeholder="you@example.com">
      </label>
      <button type="submit" class="feedback-submit">Send feedback</button>
      <div class="feedback-status" data-feedback-status aria-live="polite"></div>
    </form>
  </section>
</div>

{% block footer_cta %}
{% from "_notify_cta.html.j2" import notify_cta %}
<div class="footer-notify-cta" style="max-width: 760px; margin: 0 auto; padding: 0 24px;">
  {{ notify_cta(
      heading="Get the daily briefing in your inbox",
      subtext="Cuba business intelligence — sanctions, regulatory, sector analysis — delivered every morning.",
      tag="daily-briefing",
      notes="Signed up from footer CTA"
  ) }}
</div>
{% endblock %}

<footer class="site-footer">
  &copy; {{ current_year|default(2026) }} Cuban Insights ·
  <a href="/developers">API</a>
  <a href="/sitemap.xml">Sitemap</a>
</footer>

<script>
// Mobile nav toggle. The hamburger button is the only way to reach the
// nav links on screens <=768px, so this script is required, not nice-to-have.
(function initNavToggle() {
  var btn = document.querySelector('.top-nav .nav-toggle');
  var nav = document.querySelector('.top-nav');
  if (!btn || !nav) return;
  function setOpen(open) {
    nav.classList.toggle('is-open', open);
    btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  }
  btn.addEventListener('click', function() {
    setOpen(!nav.classList.contains('is-open'));
  });
  nav.querySelectorAll('.nav-links a').forEach(function(a) {
    a.addEventListener('click', function() { setOpen(false); });
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') setOpen(false);
  });
})();

// Auto-inject a Share button into every breadcrumbs row. This means tools,
// calendar, sanctions tracker, blog index, etc. all get a consistent share
// affordance without per-template edits. Pages can still place additional
// .share-btn elements anywhere they want.
(function autoInjectBreadcrumbShare() {
  var canonicalEl = document.querySelector('link[rel="canonical"]');
  var canonical = (canonicalEl && canonicalEl.getAttribute('href')) || window.location.href;
  var title = document.title || 'Cuban Insights';
  document.querySelectorAll('nav.breadcrumbs').forEach(function(crumbs) {
    if (crumbs.querySelector('.share-btn')) return;
    var btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'share-btn breadcrumb-share';
    btn.setAttribute('data-share-url', canonical);
    btn.setAttribute('data-share-title', title);
    btn.setAttribute('aria-label', 'Share this page');
    btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' +
      '<circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>' +
      '<line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>' +
      '</svg><span class="share-btn-label">Share</span>';
    crumbs.appendChild(btn);
  });
})();

// Auto-inject a Notify Me button into breadcrumbs when an inline .notify-cta
// exists on the page. Clicking opens the notify modal pre-filled with the
// contextual heading and tag from the inline CTA.
(function autoInjectNotifyPill() {
  var cta = document.querySelector('.notify-cta');
  if (!cta) return;
  var tag = cta.getAttribute('data-notify-tag') || '';
  var heading = cta.querySelector('h3');
  var headingText = heading ? heading.textContent : 'Get notified';
  var subtext = cta.querySelector('p');
  var subtextText = subtext ? subtext.textContent : '';
  var notes = cta.getAttribute('data-notify-notes') || '';

  document.querySelectorAll('nav.breadcrumbs').forEach(function(crumbs) {
    if (crumbs.querySelector('.notify-pill')) return;
    var pill = document.createElement('button');
    pill.type = 'button';
    pill.className = 'notify-pill';
    pill.setAttribute('aria-label', 'Get notified');
    pill.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' +
      '<path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>' +
      '<path d="M13.73 21a2 2 0 0 1-3.46 0"/>' +
      '</svg><span>Notify Me</span>';
    pill.addEventListener('click', function() {
      openNotifyModal(headingText, subtextText, tag, notes);
    });
    if (!sessionStorage.getItem('notify-bell-rang')) {
      pill.classList.add('is-ringing');
      sessionStorage.setItem('notify-bell-rang', '1');
    }
    crumbs.appendChild(pill);
  });
})();

function openNotifyModal(heading, subtext, tag, notes) {
  var overlay = document.getElementById('notify-modal-overlay');
  var headingEl = document.getElementById('notify-modal-heading');
  var subtextEl = document.getElementById('notify-modal-subtext');
  var form = document.getElementById('notify-modal-form');
  headingEl.textContent = heading;
  subtextEl.textContent = subtext;
  form.setAttribute('data-notify-tag', tag);
  form.setAttribute('data-notify-notes', notes);
  overlay.classList.add('is-open');
  setTimeout(function() { form.querySelector('input[name="email"]').focus(); }, 50);
}

(function initNotifyModal() {
  var overlay = document.getElementById('notify-modal-overlay');
  var closeBtn = document.getElementById('notify-modal-close');
  var form = document.getElementById('notify-modal-form');
  if (!overlay || !form) return;

  function close() { overlay.classList.remove('is-open'); }
  closeBtn.addEventListener('click', close);
  overlay.addEventListener('click', function(e) { if (e.target === overlay) close(); });
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') close(); });

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var emailInput = form.querySelector('input[name="email"]');
    var nameInput = form.querySelector('input[name="name"]');
    var btn = form.querySelector('.notify-modal-submit');
    var email = emailInput.value.trim();
    if (!email) return;

    var tag = form.getAttribute('data-notify-tag') || '';
    var notes = form.getAttribute('data-notify-notes') || '';
    var name = nameInput ? nameInput.value.trim() : '';
    if (name) notes = name + ' — ' + notes;

    btn.disabled = true;
    btn.textContent = 'Subscribing…';

    var payload = { email: email, source_page: window.location.pathname };
    if (tag) payload.tags = [tag];
    if (notes) payload.notes = notes;

    fetch('/api/subscribe', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.ok) {
        if (typeof gtag === 'function') {
          gtag('event', 'notify_subscribe', { tag: tag, page: window.location.pathname, method: 'modal' });
        }
        form.innerHTML = '<div class="notify-modal-success">\u2713 You\'re in. We\'ll notify you.</div>';
      } else {
        btn.disabled = false;
        btn.textContent = 'Notify Me';
        alert(data.error || 'Something went wrong. Please try again.');
      }
    })
    .catch(function() {
      btn.disabled = false;
      btn.textContent = 'Notify Me';
      alert('Network error. Please try again.');
    });
  });
})();

// Share button handler — used by any .share-btn on this page (page header,
// inline buttons, breadcrumbs auto-injected, etc.). On mobile / browsers
// exposing navigator.share we open the native share sheet; on desktop we
// copy the canonical URL and show a "Link copied" toast. Falls back to
// window.location.href when no data-share-url is provided.
(function initShareButtons() {
  var toastEl = null;
  function showToast(msg) {
    if (!toastEl) {
      toastEl = document.createElement('div');
      toastEl.className = 'share-toast';
      document.body.appendChild(toastEl);
    }
    toastEl.textContent = msg;
    requestAnimationFrame(function() { toastEl.classList.add('is-visible'); });
    clearTimeout(toastEl._hideTimer);
    toastEl._hideTimer = setTimeout(function() {
      toastEl.classList.remove('is-visible');
    }, 1600);
  }
  function flashCopied(btn) {
    var label = btn.querySelector('.share-btn-label');
    var prev = label ? label.textContent : null;
    btn.classList.add('copied');
    if (label) label.textContent = 'Copied';
    setTimeout(function() {
      btn.classList.remove('copied');
      if (label && prev !== null) label.textContent = prev;
    }, 1600);
  }
  function copyToClipboard(text) {
    if (navigator.clipboard && navigator.clipboard.writeText) {
      return navigator.clipboard.writeText(text);
    }
    return new Promise(function(resolve, reject) {
      try {
        var ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        resolve();
      } catch (err) { reject(err); }
    });
  }
  document.querySelectorAll('.share-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var url = btn.getAttribute('data-share-url') || window.location.href;
      var title = btn.getAttribute('data-share-title') || document.title;
      var pathParts = window.location.pathname.split('/').filter(Boolean);
      var ctype = pathParts[0] === 'briefing' ? 'briefing' : (pathParts[0] === 'tools' ? 'tool' : 'page');
      gtag('event', 'share_click', {
        content_type: ctype,
        slug: window.location.pathname,
        method: navigator.share ? 'web_share_api' : 'clipboard'
      });
      if (navigator.share) {
        navigator.share({ title: title, url: url }).catch(function() {
          copyToClipboard(url).then(function() {
            flashCopied(btn);
            showToast('Link copied');
          }).catch(function() {});
        });
        return;
      }
      copyToClipboard(url).then(function() {
        flashCopied(btn);
        showToast('Link copied');
      }).catch(function() {
        showToast('Could not copy link');
      });
    });
  });
})();

(function initFeedbackWidget() {
  if (!window.matchMedia || !window.matchMedia('(min-width: 769px)').matches) return;
  var widget = document.querySelector('[data-feedback-widget]');
  if (!widget) return;
  var openBtn = widget.querySelector('[data-feedback-open]');
  var panel = widget.querySelector('[data-feedback-panel]');
  var closeBtn = widget.querySelector('[data-feedback-close]');
  var form = widget.querySelector('[data-feedback-form]');
  var status = widget.querySelector('[data-feedback-status]');
  var submit = form ? form.querySelector('.feedback-submit') : null;
  var textarea = form ? form.querySelector('textarea[name="message"]') : null;
  if (!openBtn || !panel || !form || !status || !submit || !textarea) return;

  function track(name, params) {
    if (typeof gtag === 'function') gtag('event', name, params || {});
  }
  function setOpen(open) {
    panel.classList.toggle('is-open', open);
    openBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
    if (open) {
      status.textContent = '';
      status.className = 'feedback-status';
      setTimeout(function() { textarea.focus(); }, 30);
      track('feedback_open', { page_path: window.location.pathname });
    }
  }
  openBtn.addEventListener('click', function() {
    setOpen(!panel.classList.contains('is-open'));
  });
  if (closeBtn) closeBtn.addEventListener('click', function() { setOpen(false); });
  document.addEventListener('keydown', function(e2) {
    if (e2.key === 'Escape') setOpen(false);
  });
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    if (window.location.protocol === 'file:') {
      status.textContent = 'Open this page through the local server to submit feedback.';
      status.className = 'feedback-status is-error';
      return;
    }
    var message = textarea.value.trim();
    var emailInput = form.querySelector('input[name="email"]');
    var email = emailInput ? emailInput.value.trim() : '';
    if (!message) {
      status.textContent = 'Please share a tool idea or workflow we can help with.';
      status.className = 'feedback-status is-error';
      return;
    }
    submit.disabled = true;
    submit.textContent = 'Sending...';
    status.textContent = '';
    status.className = 'feedback-status';
    fetch('/api/feedback', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        message: message,
        email: email,
        page_url: window.location.href
      })
    })
    .then(function(r) {
      return r.json().then(function(data) { return { ok: r.ok, data: data }; });
    })
    .then(function(result) {
      if (!result.ok || !result.data.ok) {
        throw new Error(result.data.error || 'Feedback failed, please try again.');
      }
      track('feedback_submit', { page_path: window.location.pathname, success: 'true' });
      form.reset();
      status.textContent = 'Thank you. We will review this within 48 hours.';
      status.className = 'feedback-status is-success';
      submit.textContent = 'Sent';
      setTimeout(function() {
        submit.disabled = false;
        submit.textContent = 'Send feedback';
      }, 1600);
    })
    .catch(function(err) {
      track('feedback_error', { page_path: window.location.pathname });
      status.textContent = err.message || 'Feedback failed, please try again.';
      status.className = 'feedback-status is-error';
      submit.disabled = false;
      submit.textContent = 'Send feedback';
    });
  });
})();

// Hide footer CTA if an inline notify CTA already exists on the page
(function() {
  var inlineCtas = document.querySelectorAll('.notify-cta');
  var footerCta = document.querySelector('.footer-notify-cta');
  if (footerCta && inlineCtas.length > 1) {
    footerCta.style.display = 'none';
  }
})();

function handleNotify(e, form) {
  e.preventDefault();
  var input = form.querySelector('input');
  var btn = form.querySelector('button');
  var cta = form.closest('.notify-cta');
  var email = input.value.trim();
  if (!email) return;

  var tag = cta ? cta.getAttribute('data-notify-tag') : '';
  var notes = cta ? cta.getAttribute('data-notify-notes') : '';

  btn.disabled = true;
  btn.textContent = 'Subscribing…';

  var payload = { email: email, source_page: window.location.pathname };
  if (tag) payload.tags = [tag];
  if (notes) payload.notes = notes;

  fetch('/api/subscribe', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload)
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.ok) {
      if (typeof gtag === 'function') {
        gtag('event', 'notify_subscribe', { tag: tag, page: window.location.pathname });
      }
      form.innerHTML = '<div class="notify-success">✓ You\'re in. We\'ll notify you.</div>';
    } else {
      btn.disabled = false;
      btn.textContent = 'Notify Me';
      alert(data.error || 'Something went wrong. Please try again.');
    }
  })
  .catch(function() {
    btn.disabled = false;
    btn.textContent = 'Notify Me';
    alert('Network error. Please try again.');
  });
}
</script>
</body>
</html>
