<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ seo.title }}</title>
  <meta name="description" content="{{ seo.description }}">
  <link rel="canonical" href="{{ seo.canonical }}">
  <meta name="robots" content="noindex,follow">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&family=Open+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">

  <style>
    /* =========================================================================
       Caracas Emergency Card — print-first, two-page, A4/Letter.
       Front (page 1):  Spanish-first "show this to a stranger" sheet.
       Back  (page 2):  English "for me, when I'm rattled" reference.

       On screen we draw a grey background and a white "page" with a dotted
       cut-line so the user can preview exactly how it will print. On paper
       the page barrier disappears and only the content prints.
       ========================================================================= */

    :root {
      --ink: #111;
      --ink-soft: #444;
      --rule: #222;
      --rule-soft: #999;
      --red: #cc0000;
      --red-dark: #8b0000;
      --navy: #001f44;
      --bg-shade: #f4f4f0;
      --bg-shade-strong: #e8e6dd;
      --serif: 'Libre Baskerville', 'Times New Roman', Times, serif;
      --sans: 'Open Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { background: #d9d9d4; }
    body {
      font-family: var(--sans);
      color: var(--ink);
      line-height: 1.35;
      -webkit-font-smoothing: antialiased;
      padding: 24px 0 60px;
    }

    /* On-screen "page" preview ---------------------------------------------- */
    .screen-toolbar {
      max-width: 210mm;
      margin: 0 auto 20px;
      padding: 14px 18px;
      background: #fff;
      border: 1px solid #c0c0bc;
      border-radius: 4px;
      font-size: 13px;
      color: var(--ink-soft);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
    }
    .screen-toolbar strong { color: var(--ink); font-size: 14px; }
    .screen-toolbar .actions { display: flex; gap: 10px; }
    .screen-toolbar button {
      font-family: var(--sans);
      font-size: 13px;
      font-weight: 700;
      padding: 8px 16px;
      border-radius: 3px;
      border: 1px solid var(--navy);
      background: var(--navy);
      color: #fff;
      cursor: pointer;
    }
    .screen-toolbar button.secondary { background: #fff; color: var(--navy); }

    .page {
      width: 210mm;
      min-height: 297mm;
      margin: 0 auto 24px;
      padding: 12mm 12mm 14mm;
      background: #fff;
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.18);
      position: relative;
      overflow: hidden;
    }
    .page + .page { margin-top: 32px; }
    .page::before {
      /* "page barrier" — visible only on screen so the user can see the
         physical sheet boundary before printing */
      content: "";
      position: absolute;
      inset: 0;
      border: 1px dashed #b0b0aa;
      pointer-events: none;
    }
    .page-marker {
      position: absolute;
      top: -14px; left: 50%;
      transform: translateX(-50%);
      background: var(--navy);
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.2px;
      text-transform: uppercase;
      padding: 4px 14px;
      border-radius: 999px;
    }

    /* Page header ----------------------------------------------------------- */
    .sheet-header {
      border: 3px solid var(--red);
      padding: 8px 12px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 14px;
      margin-bottom: 8mm;
    }
    .sheet-header .es {
      font-family: var(--serif);
      font-size: 22pt;
      font-weight: 700;
      color: var(--red);
      line-height: 1.05;
    }
    .sheet-header .en {
      font-family: var(--sans);
      font-size: 11pt;
      font-weight: 700;
      color: var(--ink);
      text-transform: uppercase;
      letter-spacing: 0.6px;
      text-align: right;
      line-height: 1.2;
    }
    .sheet-header .en small { display: block; font-weight: 400; font-size: 9pt; color: var(--ink-soft); margin-top: 2px; text-transform: none; letter-spacing: 0; }

    /* Big call-to-action banner under header */
    .helpme {
      background: var(--red);
      color: #fff;
      padding: 6px 12px;
      margin-bottom: 6mm;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 12px;
    }
    .helpme .es { font-family: var(--serif); font-size: 14pt; font-weight: 700; }
    .helpme .en { font-size: 9.5pt; font-weight: 600; opacity: 0.95; }

    /* Section blocks -------------------------------------------------------- */
    .block { margin-bottom: 5mm; }
    .block-title {
      font-family: var(--sans);
      font-size: 9pt;
      text-transform: uppercase;
      letter-spacing: 1.4px;
      font-weight: 800;
      color: #fff;
      background: var(--navy);
      padding: 3px 10px;
      margin-bottom: 6px;
    }
    .block-title .en {
      font-weight: 500;
      letter-spacing: 0.6px;
      text-transform: none;
      opacity: 0.85;
      font-size: 8.5pt;
      margin-left: 8px;
    }

    /* Show-this-to-driver address cards (front page) */
    .addr-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4mm; }
    .addr-grid.cols-1 { grid-template-columns: 1fr; }
    .addr {
      border: 1.2px solid var(--ink);
      padding: 6px 10px 8px;
      page-break-inside: avoid;
    }
    .addr .flag {
      display: inline-block;
      font-size: 9pt;
      font-weight: 800;
      letter-spacing: 0.5px;
      color: #fff;
      background: var(--navy);
      padding: 1px 6px;
      margin-right: 6px;
      vertical-align: middle;
    }
    .addr h3 {
      font-family: var(--serif);
      font-size: 11pt;
      font-weight: 700;
      color: var(--ink);
      display: inline;
      vertical-align: middle;
      line-height: 1.2;
    }
    .addr .address {
      font-size: 10pt;
      font-weight: 600;
      color: var(--ink);
      margin-top: 4px;
      line-height: 1.3;
    }
    .addr .phone {
      font-size: 10.5pt;
      font-weight: 700;
      color: var(--red);
      margin-top: 4px;
      letter-spacing: 0.3px;
    }
    .addr .note {
      font-size: 8.5pt;
      color: var(--ink-soft);
      margin-top: 4px;
      font-style: italic;
      line-height: 1.3;
    }

    /* Fillable lines */
    .fill {
      display: inline-block;
      border-bottom: 1.5px solid var(--ink);
      min-width: 60mm;
      height: 14px;
      vertical-align: bottom;
    }
    .fill.short { min-width: 28mm; }
    .fill.long { min-width: 100mm; }
    [contenteditable="true"]:focus { outline: 2px solid var(--navy); outline-offset: 2px; background: #f6faff; }

    /* "My info" boxes */
    .me-box {
      border: 1.5px dashed var(--ink);
      padding: 8px 10px;
      background: var(--bg-shade);
      page-break-inside: avoid;
    }
    .me-box .row { display: flex; gap: 12px; align-items: baseline; padding: 4px 0; }
    .me-box .row + .row { border-top: 1px dotted #aaa; }
    .me-box label {
      font-size: 8.5pt;
      font-weight: 800;
      color: var(--navy);
      text-transform: uppercase;
      letter-spacing: 0.7px;
      flex-shrink: 0;
      min-width: 40mm;
    }
    .me-box label .en { display: block; font-weight: 500; color: var(--ink-soft); text-transform: none; letter-spacing: 0; font-size: 7.5pt; }
    .me-box .val { flex: 1; min-height: 16px; font-size: 10.5pt; font-weight: 700; }

    /* Phone-call panel */
    .call-panel { display: grid; grid-template-columns: 1fr 1fr; gap: 4mm; margin-bottom: 5mm; }
    .call {
      border: 2px solid var(--red);
      padding: 6px 10px;
      text-align: center;
      page-break-inside: avoid;
    }
    .call .label-es { font-family: var(--serif); font-size: 11pt; font-weight: 700; color: var(--red); }
    .call .label-en { font-size: 8pt; color: var(--ink-soft); margin-bottom: 3px; }
    .call .num { font-family: var(--sans); font-size: 22pt; font-weight: 800; color: var(--ink); letter-spacing: 1px; line-height: 1.05; }
    .call .sub { font-size: 8.5pt; color: var(--ink-soft); margin-top: 2px; }

    /* Two-column body wrapper */
    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 5mm; }

    /* Generic data table */
    table.list { width: 100%; border-collapse: collapse; font-size: 9pt; }
    table.list th, table.list td { text-align: left; padding: 3px 6px; border-bottom: 1px solid #ddd; vertical-align: top; }
    table.list th { background: var(--bg-shade); font-size: 8pt; text-transform: uppercase; letter-spacing: 0.6px; color: var(--ink-soft); }
    table.list td.num { font-weight: 700; color: var(--red); white-space: nowrap; font-size: 9.5pt; }

    /* Decision tree */
    .tree { display: grid; grid-template-columns: 1fr 1fr; gap: 3mm; }
    .tree .scenario {
      border: 1px solid var(--ink);
      padding: 5px 8px;
      page-break-inside: avoid;
    }
    .tree .scenario h4 {
      font-family: var(--serif);
      font-size: 10pt;
      font-weight: 700;
      color: var(--red);
      margin-bottom: 3px;
    }
    .tree .scenario ol { margin-left: 14px; font-size: 8.5pt; line-height: 1.4; }
    .tree .scenario ol li { margin-bottom: 2px; }

    /* Safe-corridor neighbourhood lists */
    .corridor { display: grid; grid-template-columns: 1fr 1fr; gap: 4mm; font-size: 9pt; }
    .corridor .col { padding: 6px 10px; }
    .corridor .col.safe { border: 1.5px solid #1f6f3f; background: #ecf6ef; }
    .corridor .col.avoid { border: 1.5px solid var(--red); background: #fbecea; }
    .corridor h4 {
      font-size: 9pt;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      font-weight: 800;
      margin-bottom: 4px;
    }
    .corridor .col.safe h4 { color: #1f6f3f; }
    .corridor .col.avoid h4 { color: var(--red-dark); }
    .corridor ul { margin-left: 14px; }
    .corridor li { margin: 1px 0; line-height: 1.3; }

    /* Six rules grid */
    .rules { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 3mm; }
    .rule {
      border-left: 3px solid var(--red);
      padding: 3px 8px;
      background: var(--bg-shade);
      font-size: 8.5pt;
      line-height: 1.3;
      page-break-inside: avoid;
    }
    .rule strong { display: block; font-size: 9pt; color: var(--red-dark); margin-bottom: 2px; }

    /* Spanish phrases box */
    .phrases { columns: 2; column-gap: 6mm; font-size: 9pt; }
    .phrases .ph { break-inside: avoid; padding: 3px 0; border-bottom: 1px dotted #ccc; }
    .phrases .ph .es { font-family: var(--serif); font-weight: 700; color: var(--ink); display: block; }
    .phrases .ph .en { font-size: 8pt; color: var(--ink-soft); display: block; }

    /* Footer */
    .sheet-footer {
      margin-top: 4mm;
      padding-top: 4px;
      border-top: 1px solid var(--ink);
      font-size: 7.5pt;
      color: var(--ink-soft);
      display: flex;
      justify-content: space-between;
      gap: 16px;
    }

    /* ------------------ PRINT RULES --------------------------------------- */
    @page {
      size: A4;
      margin: 10mm 10mm 12mm;
    }
    @media print {
      html, body { background: #fff; }
      body { padding: 0; }
      .screen-toolbar, .page-marker { display: none !important; }
      .page {
        width: auto;
        min-height: auto;
        margin: 0;
        padding: 0;
        box-shadow: none;
        page-break-after: always;
      }
      .page:last-of-type { page-break-after: auto; }
      .page::before { display: none; }
      [contenteditable="true"] { outline: none !important; background: transparent !important; }
      a { color: inherit; text-decoration: none; }
    }

    @media (max-width: 860px) {
      .page { width: 100%; padding: 16px; box-shadow: none; }
      .addr-grid, .call-panel, .two-col, .tree, .corridor, .rules { grid-template-columns: 1fr; }
      .phrases { columns: 1; }
    }
  </style>
</head>
<body>

  <div class="screen-toolbar">
    <div>
      <strong>Caracas Emergency Card — print preview</strong><br>
      Two A4 pages, double-sided. Edit any underlined field directly in the page, then print.
    </div>
    <div class="actions">
      <button type="button" class="secondary" onclick="resetFields()">Clear my info</button>
      <button type="button" onclick="window.print()">Print this card</button>
    </div>
  </div>

  {# =====================================================================
     PAGE 1 — FRONT — Spanish-first "show this to a stranger / driver"
     ===================================================================== #}
  <article class="page" data-page="front">
    <span class="page-marker">Page 1 / Front · Show this to anyone</span>

    <header class="sheet-header">
      <div class="es">EMERGENCIA<br>POR FAVOR AYÚDEME</div>
      <div class="en">
        EMERGENCY · PLEASE HELP ME
        <small>I am a foreign visitor. Please call one of the numbers below or take me to one of these addresses.</small>
      </div>
    </header>

    <div class="helpme">
      <div class="es">Soy un(a) visitante extranjero(a). No hablo español bien.</div>
      <div class="en">If I am unconscious or in trouble, please help.</div>
    </div>

    {# ---- WHO I AM (fillable) ---- #}
    <section class="block">
      <div class="block-title">Mis datos <span class="en">My details</span></div>
      <div class="me-box">
        <div class="row"><label>Nombre <span class="en">Name</span></label><div class="val" contenteditable="true" data-field="name"></div></div>
        <div class="row"><label>Pasaporte # <span class="en">Passport #</span></label><div class="val" contenteditable="true" data-field="passport"></div></div>
        <div class="row"><label>Nacionalidad <span class="en">Nationality</span></label><div class="val" contenteditable="true" data-field="nationality"></div></div>
        <div class="row"><label>Tipo de sangre <span class="en">Blood type</span></label><div class="val" contenteditable="true" data-field="blood"></div></div>
        <div class="row"><label>Alergias / medicinas <span class="en">Allergies / meds</span></label><div class="val" contenteditable="true" data-field="medical"></div></div>
        <div class="row"><label>Mi hotel <span class="en">My hotel</span></label><div class="val" contenteditable="true" data-field="hotel"></div></div>
        <div class="row"><label>Tel. del hotel <span class="en">Hotel phone</span></label><div class="val" contenteditable="true" data-field="hotel_phone"></div></div>
      </div>
    </section>

    {# ---- BIG NUMBERS A STRANGER CAN DIAL ---- #}
    <section class="block">
      <div class="block-title">Llame a este número <span class="en">Please call this number</span></div>
      <div class="call-panel">
        <div class="call">
          <div class="label-es">Emergencias locales</div>
          <div class="label-en">Local emergency services</div>
          <div class="num">911</div>
          <div class="sub">Policía / Ambulancia / Bomberos</div>
        </div>
        <div class="call">
          <div class="label-es">Mi embajada (24 h)</div>
          <div class="label-en">My embassy after-hours line</div>
          <div class="num" contenteditable="true" data-field="my_embassy_phone">+1 202 501-4444</div>
          <div class="sub" contenteditable="true" data-field="my_embassy_label">US — circle the embassy on the back</div>
        </div>
      </div>
    </section>

    {# ---- ADDRESSES TO SHOW THE DRIVER ---- #}
    <section class="block">
      <div class="block-title">Lléveme a una de estas direcciones <span class="en">Please take me to one of these addresses</span></div>

      <div class="addr-grid cols-1" style="margin-bottom: 4mm;">
        <div class="addr" style="border-color: var(--red); border-width: 2px;">
          <span class="flag" style="background: var(--red);">HOSPITAL</span>
          <h3>Si estoy herido(a) — lléveme al hospital privado más cercano</h3>
          <div class="note">If I am injured, take me to the nearest private hospital below. Avoid public hospitals.</div>
        </div>
      </div>

      <div class="addr-grid">
        {% for m in medical[:4] %}
        <div class="addr">
          <span class="flag" style="background: var(--red-dark);">HOSP</span>
          <h3>{{ m.name }}</h3>
          <div class="address">{{ m.neighborhood }} · Caracas</div>
          {% if m.phone %}<div class="phone">{{ m.phone }}</div>{% endif %}
          <div class="note">{{ m.notes }}</div>
        </div>
        {% endfor %}
      </div>
    </section>

    {# ---- EMBASSIES — Spanish addresses for taxi drivers ---- #}
    <section class="block">
      <div class="block-title">Embajadas en Caracas <span class="en">Embassies — circle yours, then show this to the driver</span></div>
      <div class="addr-grid">
        {% for e in embassies_top %}
        <div class="addr">
          <span class="flag">{{ e.short }}</span>
          <h3>Embajada de {{ e.country_es }}</h3>
          <div class="address">{{ e.address }}</div>
          {% if e.phone %}<div class="phone">{{ e.phone }}</div>{% endif %}
          {% if e.after_hours and e.after_hours != e.phone %}<div class="note">24h: {{ e.after_hours }}</div>{% endif %}
        </div>
        {% endfor %}
      </div>
    </section>

    <footer class="sheet-footer">
      <span>Caracas Emergency Card · Front · Updated {{ updated_label }}</span>
      <span>caracasresearch.com/travel/emergency-card</span>
    </footer>
  </article>

  {# =====================================================================
     PAGE 2 — BACK — English "for me, when I'm rattled"
     ===================================================================== #}
  <article class="page" data-page="back">
    <span class="page-marker">Page 2 / Back · For me to reference</span>

    <header class="sheet-header">
      <div class="es" style="color: var(--navy);">PARA MÍ MISMO(A)</div>
      <div class="en" style="color: var(--navy);">
        FOR ME · WHAT TO DO IN AN INCIDENT
        <small>Calm. Read top to bottom. Call the right number first.</small>
      </div>
    </header>

    {# ---- DECISION TREE ---- #}
    <section class="block">
      <div class="block-title">Do this first <span class="en">Decision tree by scenario</span></div>
      <div class="tree">
        <div class="scenario">
          <h4>1. Crime / robbery / kidnap attempt</h4>
          <ol>
            <li>Comply with the attacker. Hand over the decoy wallet.</li>
            <li>Once safe, call your embassy 24 h line (front of card).</li>
            <li>Then call your security firm: <strong>Crisis24 +1 877 484-1610</strong> or <strong>ISOS +1 215 942-8478</strong>.</li>
            <li>File a police report only after embassy guidance.</li>
          </ol>
        </div>
        <div class="scenario">
          <h4>2. Medical emergency</h4>
          <ol>
            <li>Call ISOS or your insurer first — they coordinate the hospital and direct billing.</li>
            <li>Go to a <strong>private</strong> hospital (front of card). Avoid public hospitals.</li>
            <li>Show the medical strip on the front (blood type, meds, allergies).</li>
          </ol>
        </div>
        <div class="scenario">
          <h4>3. Detained at a checkpoint (GNB / PNB)</h4>
          <ol>
            <li>Be polite. Do not photograph or argue.</li>
            <li>Present passport + visa. Do not sign anything.</li>
            <li>Insist on embassy notification. Memorise the unit name and badge numbers.</li>
            <li>Call your embassy as soon as released.</li>
          </ol>
        </div>
        <div class="scenario">
          <h4>4. Lost / stolen passport</h4>
          <ol>
            <li>Use the photocopy in your other shoe / hotel safe.</li>
            <li>Walk in to your embassy during business hours.</li>
            <li>File a denuncia at CICPC <em>only</em> if your embassy asks for one.</li>
            <li>Cancel cards via the numbers written below.</li>
          </ol>
        </div>
      </div>
    </section>

    <div class="two-col">
      {# ---- EMERGENCY NUMBERS ---- #}
      <section class="block">
        <div class="block-title">Phone numbers</div>
        <table class="list">
          <tbody>
            {% for e in emergency %}
            <tr>
              <td>{{ e.label }}</td>
              <td class="num">{{ e.number }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </section>

      {# ---- MY CONTACTS ---- #}
      <section class="block">
        <div class="block-title">My in-country contacts</div>
        <div class="me-box">
          <div class="row"><label>Driver / fixer</label><div class="val" contenteditable="true" data-field="driver"></div></div>
          <div class="row"><label>Driver plate</label><div class="val" contenteditable="true" data-field="driver_plate"></div></div>
          <div class="row"><label>Insurer 24/7</label><div class="val" contenteditable="true" data-field="insurer"></div></div>
          <div class="row"><label>Policy #</label><div class="val" contenteditable="true" data-field="policy"></div></div>
          <div class="row"><label>Home contact</label><div class="val" contenteditable="true" data-field="home_contact"></div></div>
          <div class="row"><label>Home WhatsApp</label><div class="val" contenteditable="true" data-field="home_whatsapp"></div></div>
          <div class="row"><label>Bank cancel #</label><div class="val" contenteditable="true" data-field="bank"></div></div>
          <div class="row"><label>Flight out</label><div class="val" contenteditable="true" data-field="flight"></div></div>
        </div>
      </section>
    </div>

    {# ---- SAFE / AVOID CORRIDOR ---- #}
    <section class="block">
      <div class="block-title">Safe corridor — stay east-central, daylight</div>
      <div class="corridor">
        <div class="col safe">
          <h4>Stay inside</h4>
          <ul>
            <li>Las Mercedes</li>
            <li>La Castellana</li>
            <li>Altamira</li>
            <li>El Rosal · Chacao</li>
            <li>Los Palos Grandes</li>
            <li>Campo Alegre · Country Club</li>
            <li>Valle Arriba (residential)</li>
          </ul>
        </div>
        <div class="col avoid">
          <h4>Do not enter</h4>
          <ul>
            <li>Petare</li>
            <li>Catia</li>
            <li>23 de Enero</li>
            <li>El Valle</li>
            <li>Antímano</li>
            <li>Any cerro / barrio (informal hillside)</li>
            <li>Maiquetía / Catia La Mar after dark</li>
          </ul>
        </div>
      </div>
    </section>

    {# ---- SIX NON-NEGOTIABLE RULES ---- #}
    <section class="block">
      <div class="block-title">Six non-negotiable rules</div>
      <div class="rules">
        <div class="rule"><strong>Never a street taxi</strong>Pre-arrange every car. Express kidnap starts with unlicensed taxis.</div>
        <div class="rule"><strong>Move 07:00–18:00</strong>Schedule all hotel ↔ meeting ↔ airport moves in daylight.</div>
        <div class="rule"><strong>Low profile</strong>No watch, no jewellery, no DSLR, no phone in hand. Branded laptop bags off.</div>
        <div class="rule"><strong>Decoy wallet</strong>$20–40 + an expired card to hand over. Real funds in money belt.</div>
        <div class="rule"><strong>Comply at GNB</strong>Polite. Passport + visa. Do not photograph. Do not negotiate.</div>
        <div class="rule"><strong>Two-deep comms</strong>Itinerary + check-ins to a contact at home twice daily.</div>
      </div>
    </section>

    {# ---- MONEY ---- #}
    <section class="block">
      <div class="block-title">Money cheat-sheet</div>
      <table class="list">
        <tbody>
          <tr><td><strong>Cash</strong></td><td>USD only · post-2009 series · undamaged · small bills ($1, $5, $10, $20). Bring $200–500/wk.</td></tr>
          <tr><td><strong>Cards</strong></td><td>Visa more reliable than Mastercard / Amex. Many merchants prefer Zelle.</td></tr>
          <tr><td><strong>Zelle</strong></td><td>Set up a US Zelle account before flying — informal default cashless rail.</td></tr>
          <tr><td><strong>ATMs</strong></td><td>Last resort. Tiny daily Bs. limits, frequent cash-out conditions.</td></tr>
          <tr><td><strong>Rate</strong></td><td>Two rates: BCV official + parallel (typically 25–35% higher). Confirm before negotiating.</td></tr>
        </tbody>
      </table>
    </section>

    {# ---- SPANISH PHRASES ---- #}
    <section class="block">
      <div class="block-title">Essential Spanish phrases</div>
      <div class="phrases">
        <div class="ph"><span class="es">Necesito ayuda.</span><span class="en">I need help.</span></div>
        <div class="ph"><span class="es">Llame a la policía.</span><span class="en">Call the police.</span></div>
        <div class="ph"><span class="es">Llame a una ambulancia.</span><span class="en">Call an ambulance.</span></div>
        <div class="ph"><span class="es">Lléveme al hospital privado.</span><span class="en">Take me to the private hospital.</span></div>
        <div class="ph"><span class="es">Lléveme a la embajada de [país].</span><span class="en">Take me to the [country] embassy.</span></div>
        <div class="ph"><span class="es">No hablo español.</span><span class="en">I don't speak Spanish.</span></div>
        <div class="ph"><span class="es">Necesito un médico.</span><span class="en">I need a doctor.</span></div>
        <div class="ph"><span class="es">Me robaron / Me asaltaron.</span><span class="en">I was robbed / mugged.</span></div>
        <div class="ph"><span class="es">Perdí mi pasaporte.</span><span class="en">I lost my passport.</span></div>
        <div class="ph"><span class="es">Soy diabético(a).</span><span class="en">I am diabetic.</span></div>
        <div class="ph"><span class="es">Soy alérgico(a) a…</span><span class="en">I am allergic to…</span></div>
        <div class="ph"><span class="es">Llame a este número, por favor.</span><span class="en">Call this number, please.</span></div>
        <div class="ph"><span class="es">¿Cuánto cuesta? — En dólares.</span><span class="en">How much? — In dollars.</span></div>
        <div class="ph"><span class="es">Pare aquí, por favor.</span><span class="en">Stop here, please.</span></div>
        <div class="ph"><span class="es">No tengo más dinero.</span><span class="en">I have no more money.</span></div>
        <div class="ph"><span class="es">Mi familia está en [país].</span><span class="en">My family is in [country].</span></div>
      </div>
    </section>

