{% extends "_base.html.j2" %}

{% block head_extra %}
<style>
  .calc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin: 24px 0; }
  @media (max-width: 800px) { .calc-grid { grid-template-columns: 1fr; } }
  .calc-card { background: var(--white); border: 1px solid var(--sr-gray-light); border-radius: 4px; padding: 22px; }
  .calc-card h2 { font-family: var(--font-serif); color: var(--sr-blue-dark); font-size: 18px; margin-bottom: 14px; }
  .field { margin-bottom: 14px; }
  .field label { display: block; font-size: 12px; text-transform: uppercase; letter-spacing: 0.7px; color: var(--sr-gray-text); margin-bottom: 4px; }
  .field input, .field select { width: 100%; padding: 10px 12px; border: 1px solid var(--sr-gray-light); border-radius: 3px; font-size: 14px; }
  .field .hint { font-size: 11px; color: var(--sr-gray-text); margin-top: 3px; }

  .result-headline { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; margin-bottom: 16px; }
  .res-card { background: var(--sr-gray-bg); padding: 14px; border-radius: 3px; text-align: center; border-left: 3px solid var(--sr-blue); }
  .res-card.bad { border-left-color: var(--sr-red); }
  .res-card.good { border-left-color: #2e7d32; }
  .res-card .lbl { font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--sr-gray-text); }
  .res-card .val { font-family: var(--font-serif); font-weight: 700; font-size: 20px; color: var(--sr-blue-dark); margin-top: 4px; }

  table.cf-table { width: 100%; border-collapse: collapse; font-size: 13px; margin-top: 8px; }
  table.cf-table th { background: var(--sr-blue); color: var(--white); padding: 8px 10px; text-align: right; font-size: 11px; text-transform: uppercase; }
  table.cf-table th:first-child, table.cf-table td:first-child { text-align: left; }
  table.cf-table td { padding: 7px 10px; border-bottom: 1px solid var(--sr-gray-light); text-align: right; font-variant-numeric: tabular-nums; }
  table.cf-table tr:last-child td { font-weight: 700; background: var(--sr-gray-bg); }

  .gate { margin-top: 24px; background: linear-gradient(135deg, var(--sr-blue) 0%, var(--sr-blue-dark) 100%); color: var(--white); padding: 24px; border-radius: 4px; }
  .gate h3 { font-family: var(--font-serif); font-size: 20px; margin-bottom: 6px; }
  .gate form { display: flex; gap: 8px; margin-top: 14px; }
  .gate input { flex: 1; padding: 12px 14px; border: none; border-radius: 3px; font-size: 14px; }
  .gate button { background: var(--white); color: var(--sr-blue-dark); border: none; padding: 12px 20px; font-weight: 700; cursor: pointer; border-radius: 3px; }

  .sector-context { background: var(--sr-gray-bg); border-left: 3px solid var(--sr-blue); padding: 12px 14px; font-size: 13px; color: var(--sr-dark-text); margin: 14px 0; }

  table.bench-table { width: 100%; border-collapse: collapse; font-size: 13px; margin: 12px 0 24px; }
  table.bench-table th, table.bench-table td { padding: 8px 10px; border-bottom: 1px solid var(--sr-gray-light); text-align: left; vertical-align: top; }
  table.bench-table th { background: var(--sr-gray-bg); color: var(--sr-blue-dark); font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; }
  table.bench-table td.num { font-variant-numeric: tabular-nums; text-align: right; white-space: nowrap; }
</style>
{% endblock %}

{% block content %}
<section class="container-wide">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <a href="/invest-in-cuba">Invest in Cuba</a><span>/</span>
    <span>Investment ROI Calculator</span>
  </nav>

  <header style="margin: 16px 0 16px;">
    <div style="font-size:12px; text-transform:uppercase; letter-spacing:1.4px; color:#cc0000; font-weight:700;">
      Free tool · Risk-adjusted scenario modelling
    </div>
    <h1 style="font-family:var(--font-serif); font-size:32px; color:var(--sr-blue-dark); margin:8px 0 10px;">
      Cuba Investment ROI Calculator
    </h1>
    <p style="font-family:var(--font-serif); font-style:italic; color:var(--sr-gray-text); font-size:17px; max-width: 820px;">
      IRR, NPV, and multi-year after-tax cash flow for a Cuba investment across seven sectors, with risk premiums baked in for Helms-Burton, MLC friction, and the CACR overlay.
    </p>
  </header>

  <div class="calc-grid">
    <div class="calc-card">
      <h2>Inputs</h2>
      <div class="field">
        <label for="sector">Sector</label>
        <!--
          Defaults below are anchored to 2024-2025 Caribbean / EM-comparable
          benchmarks (see "Where the sector defaults come from" section).
          data-rev = USD/MLC nominal revenue growth, data-margin = EBITDA
          margin, data-rp = Cuba-specific country/sector risk premium added
          on top of the user's base USD WACC. Helms-Burton Title III
          trafficking-claim risk and CACR overlay dominate the high-end
          premiums (tourism on confiscated property, hospitality JV with
          GAESA, banking on FINCIMEX rails).
        -->
        <select id="sector">
          <option value="tourism"     data-rev="0.12" data-margin="0.28" data-rp="0.16">Tourism &amp; Hospitality (Helms-Burton Title III risk)</option>
          <option value="mipyme"      data-rev="0.18" data-margin="0.22" data-rp="0.10">MIPYMES (private sector under §515.574)</option>
          <option value="mariel_zed"  data-rev="0.10" data-margin="0.32" data-rp="0.13">Mariel ZED (light manufacturing &amp; logistics)</option>
          <option value="biotech"     data-rev="0.08" data-margin="0.35" data-rp="0.14">Biotech &amp; Pharma (BioCubaFarma)</option>
          <option value="mining"      data-rev="0.07" data-margin="0.34" data-rp="0.14">Mining (nickel, cobalt — Moa)</option>
          <option value="telecom"     data-rev="0.09" data-margin="0.38" data-rp="0.13">Telecom &amp; Digital (ETECSA monopoly)</option>
          <option value="agriculture" data-rev="0.06" data-margin="0.16" data-rp="0.10">Agriculture (domestic / ALIMPORT)</option>
        </select>
        <div class="hint" id="sector-hint">Each sector ships with a baseline USD revenue growth rate, EBITDA margin, and Cuba-specific risk premium added to your discount rate. Override any of them below.</div>
      </div>
      <div class="field">
        <label for="capex">Initial capital deployed (USD)</label>
        <input type="number" id="capex" value="2000000" min="10000" step="10000">
      </div>
      <div class="field">
        <label for="rev0">Year-1 revenue (USD)</label>
        <input type="number" id="rev0" value="800000" min="0" step="10000">
      </div>
      <div class="field">
        <label for="years">Holding period (years)</label>
        <input type="number" id="years" value="7" min="1" max="20" step="1">
      </div>
      <div class="field">
        <label for="growth">Annual revenue growth (override)</label>
        <input type="number" id="growth" value="" placeholder="auto from sector" step="0.01">
        <div class="hint">Decimal. e.g. 0.10 = 10%/yr. Leave blank to use sector default.</div>
      </div>
      <div class="field">
        <label for="margin">EBITDA margin (override)</label>
        <input type="number" id="margin" value="" placeholder="auto from sector" step="0.01">
        <div class="hint">Decimal. e.g. 0.38 = 38% EBITDA. Distinct from operating (EBIT) margin — D&amp;A is treated implicitly via maintenance capex.</div>
      </div>
      <div class="field">
        <label for="tax">Effective tax rate</label>
        <input type="number" id="tax" value="0.35" min="0" max="0.6" step="0.01">
        <div class="hint">Default 35% — the headline Cuban corporate income-tax rate (Ley 113). Mariel ZED projects can negotiate down to 12% (or zero) for an initial 8-10 year holiday under Ley 118 / Decreto 313; foreign-invested JVs typically run 15%.</div>
      </div>
      <div class="field">
        <label for="maintcapex">Maintenance capex (% of revenue)</label>
        <input type="number" id="maintcapex" value="0.05" min="0" max="0.5" step="0.005">
        <div class="hint">Default 5%. Keeps existing assets productive — reduce for asset-light services, raise for capex-heavy upstream / mining.</div>
      </div>
      <div class="field">
        <label for="discount">Base discount rate (USD WACC)</label>
        <input type="number" id="discount" value="0.10" min="0" step="0.005">
        <div class="hint">Sector-specific Cuba risk premium added on top.</div>
      </div>
      <div class="field">
        <label for="exit">Exit multiple on year-{n} EBITDA</label>
        <input type="number" id="exit" value="4" min="0" step="0.5">
      </div>
    </div>

    <div class="calc-card">
      <h2>Results</h2>
      <div class="result-headline">
        <div class="res-card" id="card-irr"><div class="lbl">IRR</div><div class="val" id="r-irr">—</div></div>
        <div class="res-card" id="card-npv"><div class="lbl">NPV (today)</div><div class="val" id="r-npv">—</div></div>
        <div class="res-card" id="card-mom"><div class="lbl">Money-on-money</div><div class="val" id="r-mom">—</div></div>
      </div>
      <div class="sector-context" id="risk-context">
        Risk-adjusted discount rate: <strong id="r-rate">—</strong>
        (= base WACC + sector premium).
        Sector-specific Cuba premium reflects CACR / OFAC sanctions overlay,
        Helms-Burton Title III trafficking-claim exposure, MLC convertibility
        friction, no US-issued payment cards, and regulatory volatility. See
        the <a href="/sectors/tourism" id="sector-link" style="color: var(--sr-blue);">sector landing page</a>
        for the underlying analysis.
      </div>
      <table class="cf-table" id="cf-table">
        <thead><tr><th>Year</th><th>Revenue</th><th>EBITDA</th><th>Tax</th><th>Maint. capex</th><th>FCF</th><th>Disc. CF</th></tr></thead>
        <tbody></tbody>
      </table>
    </div>
  </div>

  <div class="gate">
    <h3>Get the full PDF investor model</h3>
    <p>Subscribe for the daily Cuban Insights briefing and we'll email you a polished PDF version of this scenario, plus a Google Sheet you can fork.</p>
    <form id="gate-form">
      <input type="email" id="gate-email" placeholder="you@firm.com" required>
      <button type="submit">Send the model</button>
    </form>
    <div id="gate-msg" style="margin-top:8px; font-size:13px; min-height:18px;"></div>
  </div>

  <h2 style="font-family:var(--font-serif); color:var(--sr-blue-dark); margin: 32px 0 8px;">How this calculator works</h2>
  <p style="margin: 0 0 4px;">Order-of-magnitude estimate. Discount = your USD WACC + a sector-specific Cuba risk premium. Not a substitute for a fully diligenced model.</p>
  <details class="show-more">
    <summary><span class="label-closed">Methodology &amp; FCF formula</span><span class="label-open">Hide</span></summary>
    <div class="show-more__body">
      <p>The model projects a deterministic revenue / EBITDA schedule using the sector defaults you can override, applies the chosen tax rate to EBITDA to approximate operating cash taxes, deducts maintenance capex as a percent of revenue, then applies an exit multiple to terminal-year EBITDA.</p>
      <p style="margin-top:8px;">FCF formula: <code>FCF&nbsp;=&nbsp;EBITDA&nbsp;×&nbsp;(1&nbsp;−&nbsp;tax)&nbsp;−&nbsp;maintenance&nbsp;capex</code>. Terminal year adds <code>exit&nbsp;multiple&nbsp;×&nbsp;terminal&nbsp;EBITDA</code> on top.</p>
    </div>
  </details>

  <h2 style="font-family:var(--font-serif); color:var(--sr-blue-dark); margin: 24px 0 8px;">Where the sector defaults come from</h2>
  <p style="margin: 0 0 12px;">2024–2025 Caribbean / EM-comparable benchmarks, adjusted for Cuba&rsquo;s specific overlay (CACR, Helms-Burton Title III, MLC stack, payment friction). Full methodology in the <a href="/invest-in-cuba">pillar guide</a>.</p>

  <table class="bench-table">
    <thead>
      <tr><th>Sector</th><th class="num">EBITDA margin</th><th class="num">Rev. growth</th><th class="num">Cuba risk premium</th><th>Reference comp set</th></tr>
    </thead>
    <tbody>
      <tr><td>Tourism &amp; Hospitality</td><td class="num">28%</td><td class="num">12%</td><td class="num">16%</td><td>Branded Caribbean hotels run 25–35% EBITDA margins. Premium dominated by Helms-Burton Title III exposure on confiscated property and JV partner concentration with GAESA / Gaviota / Habaguanex.</td></tr>
      <tr><td>MIPYMES (private sector)</td><td class="num">22%</td><td class="num">18%</td><td class="num">10%</td><td>Newly-legal Cuban private firms (since Decreto-Ley 46/2021). Highest growth reflects formalisation off a near-zero base; lowest premium because §515.574 explicitly authorises engagement.</td></tr>
      <tr><td>Mariel ZED</td><td class="num">32%</td><td class="num">10%</td><td class="num">13%</td><td>EM SEZ benchmarks (Dominican Republic free zones, Panama Pacífico) at 28–35% EBITDA. ZED-specific tax holiday lowers cash burden materially below headline 35%.</td></tr>
      <tr><td>Biotech &amp; Pharma (BioCubaFarma)</td><td class="num">35%</td><td class="num">8%</td><td class="num">14%</td><td>BioCubaFarma generics + immunotherapy comps; mid-30s EBITDA. Premium reflects CACR licensing exposure on US clinical trials and FDA pathway uncertainty.</td></tr>
      <tr><td>Mining (nickel, cobalt — Moa)</td><td class="num">34%</td><td class="num">7%</td><td class="num">14%</td><td>Sherritt-style nickel/cobalt JV comps at Ni ~$16,000/t; battery-metal demand pull. Premium reflects sustained Helms-Burton exposure (Title III claims around Moa).</td></tr>
      <tr><td>Telecom &amp; Digital</td><td class="num">38%</td><td class="num">9%</td><td class="num">13%</td><td>EM mobile operators run 35–45% EBITDA margins. ETECSA monopoly limits foreign equity entry; CACR §515.578 carves out specific telecom GLs.</td></tr>
      <tr><td>Agriculture (domestic / ALIMPORT)</td><td class="num">16%</td><td class="num">6%</td><td class="num">10%</td><td>Domestic-market food producers; commodity-cycle exposed and constrained by ALIMPORT pricing. Lowest premium because least sanctions-exposed.</td></tr>
    </tbody>
  </table>

  <script>
    (function() {
      var fmt = function(n) {
        if (!isFinite(n)) return '—';
        return '$' + Math.round(n).toLocaleString('en-US');
      };
      var pct = function(n) {
        if (!isFinite(n)) return '—';
        return (n * 100).toFixed(1) + '%';
      };
      function irr(flows, guess) {
        guess = guess || 0.1;
        for (var i = 0; i < 200; i++) {
          var npv = 0, dnpv = 0;
          for (var t = 0; t < flows.length; t++) {
            var f = flows[t];
            var d = Math.pow(1 + guess, t);
            npv += f / d;
            dnpv += -t * f / Math.pow(1 + guess, t + 1);
          }
          var next = guess - npv / dnpv;
          if (!isFinite(next)) return null;
          if (Math.abs(next - guess) < 1e-7) return next;
          guess = next;
        }
        return guess;
      }
      function compute() {
        var sectorEl = document.getElementById('sector');
        var sectorOpt = sectorEl.options[sectorEl.selectedIndex];
        var defaultGrowth = parseFloat(sectorOpt.dataset.rev);
        var defaultMargin = parseFloat(sectorOpt.dataset.margin);
        var riskPremium = parseFloat(sectorOpt.dataset.rp);
        document.getElementById('sector-link').href = '/sectors/' + sectorEl.value.replace('_', '-');

        var capex = parseFloat(document.getElementById('capex').value || '0');
        var rev0 = parseFloat(document.getElementById('rev0').value || '0');
        var years = Math.max(1, Math.min(20, parseInt(document.getElementById('years').value || '7', 10)));
        var growth = parseFloat(document.getElementById('growth').value);
        if (!isFinite(growth)) growth = defaultGrowth;
        var margin = parseFloat(document.getElementById('margin').value);
        if (!isFinite(margin)) margin = defaultMargin;
        var tax = parseFloat(document.getElementById('tax').value);
        if (!isFinite(tax) || tax < 0) tax = 0;
        if (tax > 0.6) tax = 0.6;
        var maintCapexPct = parseFloat(document.getElementById('maintcapex').value);
        if (!isFinite(maintCapexPct) || maintCapexPct < 0) maintCapexPct = 0;
        var discount = parseFloat(document.getElementById('discount').value || '0.1');
        var exitMult = parseFloat(document.getElementById('exit').value || '4');

        var rate = discount + riskPremium;
        document.getElementById('r-rate').textContent = pct(rate);

        var flows = [-capex];
        var rows = ['<tr><td>0</td><td></td><td></td><td></td><td></td><td>' + fmt(-capex) + '</td><td>' + fmt(-capex) + '</td></tr>'];

        var rev = rev0, totalNpv = -capex;
        var lastEbitda = 0;
        for (var y = 1; y <= years; y++) {
          if (y > 1) rev = rev * (1 + growth);
          var ebitda = rev * margin;
          // Approximate operating cash taxes as tax * EBITDA. This is a
          // simplification (a full model would tax EBIT, not EBITDA), but
          // for an order-of-magnitude screening tool the EBITDA proxy
          // keeps the model self-consistent without forcing a separate
          // D&A schedule.
          var taxCash = Math.max(0, ebitda) * tax;
          var maintCapex = rev * maintCapexPct;
          var fcf = ebitda - taxCash - maintCapex;
          var exitVal = 0;
          if (y === years) {
            exitVal = exitMult * ebitda;
            fcf = fcf + exitVal;
          }
          flows.push(fcf);
          var disc = fcf / Math.pow(1 + rate, y);
          totalNpv += disc;
          lastEbitda = ebitda;
          rows.push(
            '<tr>' +
              '<td>' + y + '</td>' +
              '<td>' + fmt(rev) + '</td>' +
              '<td>' + fmt(ebitda) + '</td>' +
              '<td>' + fmt(-taxCash) + '</td>' +
              '<td>' + fmt(-maintCapex) + '</td>' +
              '<td>' + fmt(fcf) + (exitVal > 0 ? ' <span style="font-size:10px;color:var(--sr-gray-text);">(incl. ' + fmt(exitVal) + ' exit)</span>' : '') + '</td>' +
              '<td>' + fmt(disc) + '</td>' +
            '</tr>'
          );
        }

        var totalReturned = flows.slice(1).reduce(function(a, b) { return a + b; }, 0);
        var mom = capex > 0 ? totalReturned / capex : 0;
        var irrVal = irr(flows);

        document.getElementById('r-irr').textContent = pct(irrVal);
        document.getElementById('r-npv').textContent = fmt(totalNpv);
        document.getElementById('r-mom').textContent = mom.toFixed(2) + 'x';

        document.getElementById('card-irr').className = 'res-card ' + (irrVal > rate + 0.05 ? 'good' : (irrVal < rate ? 'bad' : ''));
        document.getElementById('card-npv').className = 'res-card ' + (totalNpv > 0 ? 'good' : 'bad');
        document.getElementById('card-mom').className = 'res-card ' + (mom > 2 ? 'good' : (mom < 1 ? 'bad' : ''));

        document.querySelector('#cf-table tbody').innerHTML = rows.join('');
      }
      ['sector','capex','rev0','years','growth','margin','tax','maintcapex','discount','exit'].forEach(function(id) {
        document.getElementById(id).addEventListener('input', compute);
        document.getElementById(id).addEventListener('change', compute);
      });
      compute();

      document.getElementById('gate-form').addEventListener('submit', function(e) {
        e.preventDefault();
        var em = document.getElementById('gate-email').value;
        var msg = document.getElementById('gate-msg');
        msg.textContent = 'Sending…';
        fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: em, source: 'roi-calculator' })
        }).then(function(r) { return r.json(); }).then(function(j) {
          if (j.ok) msg.textContent = "You're in. Check your inbox shortly for the model — and the next briefing.";
          else msg.textContent = j.error || 'Something went wrong.';
        }).catch(function() { msg.textContent = 'Network error — try again.'; });
      });
    })();
  </script>

  {% from "_related_tools.html.j2" import related_tools_nav %}
  {{ related_tools_nav(related_tools_ctx) }}

</section>
{% endblock %}
