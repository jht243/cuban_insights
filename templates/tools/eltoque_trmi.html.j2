{% extends "_base.html.j2" %}

{% block head_extra %}
<style>
  .ex-card { background: var(--white); border: 1px solid var(--sr-gray-light); border-radius: 4px; padding: 24px; margin: 20px 0; }
  .rate-headline { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; align-items: center; }
  .rate-headline .col { padding: 16px; border-radius: 3px; background: var(--sr-gray-bg); text-align: center; }
  .rate-headline .col.primary { background: var(--sr-blue); color: var(--white); }
  .rate-headline .lbl { font-size: 12px; text-transform: uppercase; letter-spacing: 1px; opacity: 0.85; }
  .rate-headline .val { font-family: var(--font-serif); font-size: 36px; font-weight: 700; margin-top: 4px; }
  .rate-headline .sub { font-size: 12px; opacity: 0.85; margin-top: 4px; }
  .rate-error { background: #fff3e0; border-left: 4px solid #f5b041; padding: 14px 18px; font-size: 14px; color: #7c4a03; border-radius: 3px; }
  .converter { display: grid; grid-template-columns: 1fr auto 1fr; gap: 12px; align-items: end; margin: 24px 0 8px; }
  .converter label { display: block; font-size: 12px; text-transform: uppercase; letter-spacing: 0.7px; color: var(--sr-gray-text); margin-bottom: 4px; }
  .converter input, .converter select { width: 100%; padding: 12px 14px; border: 1px solid var(--sr-gray-light); border-radius: 3px; font-size: 16px; }
  .converter .arrow { font-size: 22px; color: var(--sr-blue); padding: 0 8px 12px; }
  .quick-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 8px; margin-top: 16px; }
  .quick-card { background: var(--sr-gray-bg); padding: 10px 12px; border-radius: 3px; text-align: center; }
  .quick-card .from { font-size: 12px; color: var(--sr-gray-text); }
  .quick-card .to { font-family: var(--font-serif); font-size: 17px; font-weight: 700; color: var(--sr-blue-dark); }
</style>
{% endblock %}

{% block content %}
<section class="container">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <a href="/invest-in-cuba">Invest in Cuba</a><span>/</span>
    <span>elTOQUE TRMI · CUP / USD Rate</span>
  </nav>

  <header style="margin: 16px 0 16px;">
    <div style="font-size:12px; text-transform:uppercase; letter-spacing:1.4px; color:#cc0000; font-weight:700;">
      Live tool · elTOQUE TRMI informal rate + BCC official rate
    </div>
    <h1 style="font-family:var(--font-serif); font-size:32px; color:var(--sr-blue-dark); margin:8px 0 10px;">
      Cuban Peso Exchange Rate: CUP to USD Today (Real Market Rate)
    </h1>
    <p style="font-family:var(--font-serif); font-style:italic; color:var(--sr-gray-text); font-size:17px;">
      The real Cuban peso to USD rate is 10&ndash;20&times; higher than what Google shows. We display the <em>actual</em> exchange rate from elTOQUE's TRMI (tasa representativa del mercado informal), plus the BCC official rate, MLC rate, and a free converter.
    </p>
    <div style="display:flex; flex-wrap:wrap; gap:16px; align-items:center; margin-top:14px; padding:10px 14px; background: var(--sr-gray-bg); border-left:3px solid var(--sr-blue); font-size:13px; color:var(--sr-gray-text);">
      <span><strong style="color:var(--sr-dark-text);">Last updated:</strong> {{ rate_date }}</span>
      <span><strong style="color:var(--sr-dark-text);">Sources:</strong> {{ attribution }}; Banco Central de Cuba official reference</span>
    </div>
  </header>

  <div class="ex-card">
    {% if rate_usd %}
    <div class="rate-headline">
      <div class="col primary">
        <div class="lbl">Informal CUP/USD (elTOQUE TRMI)</div>
        <div class="val">{{ '%.2f' % rate_usd }} CUP</div>
        <div class="sub">per US$1 · as of {{ rate_date }}</div>
      </div>
      <div class="col">
        <div class="lbl">Informal CUP/EUR (elTOQUE)</div>
        <div class="val" style="color:var(--sr-blue-dark);">{{ '%.2f' % rate_eur if rate_eur else '—' }} CUP</div>
        <div class="sub">per €1 · as of {{ rate_date }}</div>
      </div>
    </div>

    <div class="converter">
      <div>
        <label for="amt">Amount</label>
        <input type="number" id="amt" value="100" min="0" step="any">
      </div>
      <div class="arrow">&rarr;</div>
      <div>
        <label for="dir">Convert</label>
        <select id="dir">
          <option value="usd_to_cup">USD &rarr; CUP</option>
          <option value="cup_to_usd">CUP &rarr; USD</option>
          <option value="eur_to_cup">EUR &rarr; CUP</option>
          <option value="cup_to_eur">CUP &rarr; EUR</option>
        </select>
      </div>
    </div>
    <div id="conv-result" style="text-align:center; font-family:var(--font-serif); font-size:24px; font-weight:700; color:var(--sr-blue-dark); margin-top:12px;"></div>

    <div class="quick-grid">
      {% for amt in [10, 100, 1000, 10000] %}
      <div class="quick-card">
        <div class="from">US${{ amt }}</div>
        <div class="to">{{ '{:,.0f}'.format(rate_usd * amt) }} CUP</div>
      </div>
      {% endfor %}
    </div>

    <p style="font-size:12px; color:var(--sr-gray-text); margin-top:16px;">
      Source: <a href="https://eltoque.com/tasas-de-cambio-de-moneda-en-cuba-hoy" rel="nofollow noopener" target="_blank">elTOQUE — Tasas de cambio</a>
      (TRMI methodology). Cross-check with the
      <a href="https://www.bc.gob.cu" rel="nofollow noopener" target="_blank">Banco Central de Cuba</a>
      official reference rate. Refreshed each pipeline run; cached value displayed
      below if the upstream feed is unreachable.
    </p>

    <script>
      (function() {
        var rates = { usd: {{ rate_usd }}, eur: {{ rate_eur or 'null' }} };
        var amt = document.getElementById('amt');
        var dir = document.getElementById('dir');
        var out = document.getElementById('conv-result');
        var _trmiTracked = false;
        function fmt(n, prefix, suffix) {
          if (!isFinite(n)) return '—';
          return prefix + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 4 }) + suffix;
        }
        function render() {
          var v = parseFloat(amt.value || '0');
          var d = dir.value;
          if (d === 'usd_to_cup') out.textContent = fmt(v * rates.usd, '', ' CUP');
          else if (d === 'cup_to_usd') out.textContent = fmt(v / rates.usd, 'US$', '');
          else if (d === 'eur_to_cup') out.textContent = rates.eur ? fmt(v * rates.eur, '', ' CUP') : 'EUR rate unavailable';
          else if (d === 'cup_to_eur') out.textContent = rates.eur ? fmt(v / rates.eur, '€', '') : 'EUR rate unavailable';
        }
        function renderAndTrack() {
          render();
          if (!_trmiTracked) { _trmiTracked = true; gtag('event', 'tool_used', { tool_name: 'eltoque_trmi', query: dir.value }); }
        }
        amt.addEventListener('input', renderAndTrack);
        dir.addEventListener('change', renderAndTrack);
        render();
      })();
    </script>
    {% else %}
    <div class="rate-error">
      Live elTOQUE TRMI rate unavailable right now (the upstream feed is
      intermittently reachable). The rate refreshes every pipeline run; try
      again in a few hours, or browse the most recent published value on the
      <a href="https://eltoque.com/tasas-de-cambio-de-moneda-en-cuba-hoy" rel="nofollow noopener" target="_blank">elTOQUE site</a>
      or the <a href="https://www.bc.gob.cu" rel="nofollow noopener" target="_blank">Banco Central de Cuba</a> reference page.
    </div>
    {% endif %}
  </div>

  <h2 style="font-family:var(--font-serif); color:var(--sr-blue-dark); margin: 32px 0 8px;">The CUP / MLC / USD currency stack</h2>
  <p style="margin: 0 0 8px;">Cuba runs three parallel rates: the <strong>BCC official rate</strong> (state accounting), the <strong>MLC</strong> retail token, and the <strong>elTOQUE TRMI informal rate</strong> &mdash; usually several multiples above the official one during currency stress.</p>
  <details class="show-more">
    <summary><span class="label-closed">Why this matters for investors</span><span class="label-open">Hide</span></summary>
    <div class="show-more__body">
      <p>The Banco Central de Cuba publishes an <strong>official CUP/USD reference rate</strong> used for state-enterprise accounting, customs valuations, and public-sector transactions. The state also operates the <strong>MLC (Moneda Libremente Convertible)</strong>, a partially convertible token used in MLC-only retail outlets and for hard-currency remittances. The actual day-to-day price discovery for hard currency happens in the informal market tracked by elTOQUE&rsquo;s TRMI (<em>tasa representativa del mercado informal</em>). Investors need all three layers to value Cuba-exposed cash flows, settle import bills, or repatriate JV dividends.</p>
      <p style="margin-top:10px;"><strong>Capital repatriation</strong> from Cuban joint-venture (Empresa Mixta) profits routes through the BCC-licensed banking channel, with hard-currency availability rationed by the central bank during balance-of-payments squeezes. Mariel ZED concession-holders get a more permissive regime under Ley 118 / Decreto 313, but BCC liquidity is still the binding constraint. Layer the US side on top: CACR (31 CFR Part 515) prohibits most US-person Cuba transactions absent an OFAC license, and US-issued Visa/Mastercard cards don&rsquo;t work on the island. Quote portfolio returns in USD-equivalent terms using a defensible rate &mdash; BCC official for accounting, TRMI for economic substance.</p>
    </div>
  </details>

  {% from "_notify_cta.html.j2" import notify_cta %}
  {{ notify_cta(
      heading="Get the daily briefing in your inbox",
      subtext="Cuba exchange rates, macro data, and sanctions analysis — delivered every morning before markets open.",
      tag="daily-briefing",
      notes="Signed up from El Toque TRMI tool"
  ) }}

  {% from "_related_tools.html.j2" import related_tools_nav %}
  {{ related_tools_nav(related_tools_ctx) }}

</section>
{% endblock %}
