{% extends "_base.html.j2" %}
{% from "_cluster_nav.html.j2" import cluster_nav, cluster_nav_css %}
{% from "_related_tools.html.j2" import related_tools_nav, related_tools_nav_css %}

{% block head_extra %}
{{ cluster_nav_css() }}
{{ related_tools_nav_css() }}
<style>
  .export-page__lede { font-family: var(--font-serif); font-style: italic; color: var(--sr-gray-text); font-size: 18px; max-width: 820px; }
  .export-page__body { margin-top: 24px; max-width: 980px; }
  .export-page__panel { border: 1px solid var(--sr-gray-light); border-left: 4px solid var(--sr-blue); border-radius: 4px; padding: 18px 20px; background: var(--white); margin-bottom: 16px; }
  .export-page__panel h2 { margin: 0 0 10px; font-family: var(--font-serif); color: var(--sr-blue-dark); font-size: 20px; }
  .export-page__panel p { margin: 0 0 10px; }
  .export-page__panel ul, .export-page__panel ol { margin: 10px 0 0; padding-left: 20px; }
  .export-page__panel li { margin: 7px 0; }
  .export-page__callout { background: #fff8e1; border-left-color: #f5b041; }
  .export-page__source { max-width: 980px; background: var(--sr-gray-bg); border-left-color: var(--sr-gray-text); font-size: 13px; color: var(--sr-dark-text); }
  .hub-group { margin: 34px 0 38px; }
  .hub-group__head { display: flex; justify-content: space-between; align-items: baseline; gap: 18px; border-bottom: 1px solid #d6dde6; padding-bottom: 14px; margin-bottom: 18px; }
  .hub-group__title { margin: 0; font-family: var(--font-serif); color: var(--sr-blue-dark); font-size: 28px; line-height: 1.2; }
  .hub-group__sub { margin: 0; color: var(--sr-gray-text); font-size: 14px; max-width: 620px; text-align: right; line-height: 1.45; }
  .hub-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 18px; }
  .hub-card { display: flex; flex-direction: column; min-height: 230px; padding: 22px 24px; border: 1px solid #d6dde6; border-radius: 6px; background: #fff; color: inherit; text-decoration: none; transition: border-color .15s, box-shadow .15s, transform .15s; }
  .hub-card:hover { border-color: var(--sr-blue); box-shadow: 0 10px 24px rgba(0,31,68,.08); transform: translateY(-1px); }
  .hub-card__eyebrow { display: inline-flex; align-items: center; gap: 8px; margin-bottom: 16px; font-size: 12px; font-weight: 800; letter-spacing: 1.8px; text-transform: uppercase; color: #c7251a; }
  .hub-card__eyebrow::before { content: ""; width: 11px; height: 11px; border-radius: 50%; background: #c7251a; flex: 0 0 auto; }
  .hub-card__title { margin: 0; font-family: var(--font-serif); color: #111827; font-size: 21px; line-height: 1.18; }
  .hub-card__text { margin: 14px 0 0; color: #4b5563; font-size: 15px; line-height: 1.5; }
  .hub-card__cta { margin-top: auto; padding-top: 22px; color: var(--sr-blue-dark); font-weight: 800; font-size: 15px; }
  .resource-group { margin: 34px 0 36px; max-width: 1180px; }
  .resource-group__head { display: flex; justify-content: space-between; align-items: baseline; gap: 18px; border-bottom: 1px solid #d6dde6; padding-bottom: 14px; margin-bottom: 18px; }
  .resource-group__title { margin: 0; font-family: var(--font-serif); color: var(--sr-blue-dark); font-size: 26px; line-height: 1.2; }
  .resource-group__sub { margin: 0; color: var(--sr-gray-text); font-size: 14px; max-width: 520px; text-align: right; line-height: 1.45; }
  .resource-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; }
  .resource-card { display: flex; flex-direction: column; min-height: 165px; padding: 18px 20px; border: 1px solid #d6dde6; border-radius: 6px; background: #fff; color: inherit; text-decoration: none; transition: border-color .15s, box-shadow .15s, transform .15s; }
  .resource-card:hover { border-color: var(--sr-blue); box-shadow: 0 8px 20px rgba(0,31,68,.08); transform: translateY(-1px); }
  .resource-card__title { font-family: var(--font-serif); color: #111827; font-weight: 700; font-size: 18px; line-height: 1.2; }
  .resource-card__text { margin-top: 10px; color: #4b5563; font-size: 14px; line-height: 1.45; }
  .resource-card__cta { margin-top: auto; padding-top: 16px; color: var(--sr-blue-dark); font-size: 13px; font-weight: 800; }
  .export-page__steps { counter-reset: step; list-style: none; padding-left: 0 !important; }
  .export-page__steps li { counter-increment: step; position: relative; padding-left: 34px; }
  .export-page__steps li::before { content: counter(step); position: absolute; left: 0; top: 0; width: 22px; height: 22px; border-radius: 50%; background: var(--sr-blue); color: #fff; font-size: 12px; font-weight: 700; display: inline-flex; align-items: center; justify-content: center; }
  .export-page__meta { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 18px; max-width: 980px; }
  .export-page__meta span { border: 1px solid var(--sr-gray-light); border-radius: 999px; padding: 8px 14px; font-size: 13px; line-height: 1; color: var(--sr-blue-dark); background: #f7f9fc; }
  @media (max-width: 860px) {
    .hub-group__head { display: block; }
    .hub-group__sub { margin-top: 6px; text-align: left; }
    .hub-grid { grid-template-columns: 1fr; }
    .resource-group__head { display: block; }
    .resource-group__sub { margin-top: 6px; text-align: left; }
    .resource-grid { grid-template-columns: 1fr; }
  }
</style>
{% endblock %}

{% block content %}
<section class="container export-page">
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <a href="/tools">Tools</a><span>/</span>
    <span>{{ page.short_title }}</span>
  </nav>

  <header style="margin: 16px 0 20px;">
    <div style="font-size:12px; text-transform:uppercase; letter-spacing:1.4px; color:#cc0000; font-weight:700;">
      {{ page.eyebrow }}
    </div>
    <h1 style="font-family:var(--font-serif); font-size:34px; color:var(--sr-blue-dark); margin:8px 0 10px;">
      {{ page.title }}
    </h1>
    <p class="export-page__lede">{{ page.lede }}</p>
    <div class="export-page__meta">
      {% for chip in page.chips %}
      <span>{{ chip }}</span>
      {% endfor %}
    </div>
  </header>

  {% if page.hub_groups %}
    {% for group in page.hub_groups %}
    <section class="hub-group" aria-labelledby="hub-group-{{ loop.index }}">
      <header class="hub-group__head">
        <h2 id="hub-group-{{ loop.index }}" class="hub-group__title">{{ group.heading }}</h2>
        {% if group.subheading %}<p class="hub-group__sub">{{ group.subheading }}</p>{% endif %}
      </header>
      <div class="hub-grid">
        {% for card in group.cards %}
        <a class="hub-card" href="{{ card.href }}">
          <span class="hub-card__eyebrow">{{ card.eyebrow }}</span>
          <h3 class="hub-card__title">{{ card.title }}</h3>
          <p class="hub-card__text">{{ card.text }}</p>
          <span class="hub-card__cta" aria-hidden="true">{{ card.cta }} &rarr;</span>
        </a>
        {% endfor %}
      </div>
    </section>
    {% endfor %}
  {% endif %}

  <main class="export-page__body">
    {% for section in page.sections %}
    <section class="export-page__panel{% if section.kind == 'callout' %} export-page__callout{% endif %}">
      <h2>{{ section.heading }}</h2>
      {% if section.body %}<p>{{ section.body }}</p>{% endif %}
      {% if section["items"] %}
        {% if section.ordered %}
        <ol class="export-page__steps">
        {% else %}
        <ul>
        {% endif %}
        {% for item in section["items"] %}
          <li>{{ item|safe }}</li>
        {% endfor %}
        {% if section.ordered %}</ol>{% else %}</ul>{% endif %}
      {% endif %}
    </section>
    {% endfor %}
  </main>

  {% if page.resource_modules %}
    {% for group in page.resource_modules %}
    <section class="resource-group" aria-labelledby="resource-group-{{ loop.index }}">
      <header class="resource-group__head">
        <h2 id="resource-group-{{ loop.index }}" class="resource-group__title">{{ group.heading }}</h2>
        {% if group.subheading %}<p class="resource-group__sub">{{ group.subheading }}</p>{% endif %}
      </header>
      <div class="resource-grid">
        {% for link in group.links %}
        <a class="resource-card" href="{{ link.href }}"{% if link.href.startswith('http') %} rel="nofollow noopener" target="_blank"{% endif %}>
          <span class="resource-card__title">{{ link.label }}</span>
          <span class="resource-card__text">{{ link.text }}</span>
          <span class="resource-card__cta" aria-hidden="true">Open resource &rarr;</span>
        </a>
        {% endfor %}
      </div>
    </section>
    {% endfor %}
  {% endif %}

  <section class="export-page__panel export-page__source">
    <h2>ITA Attribution</h2>
    <p>This product uses International Trade Administration data and Trade.gov content but is not endorsed or certified by the International Trade Administration.</p>
  </section>

  {{ related_tools_nav(related_tools_ctx) }}
  {{ cluster_nav(cluster_ctx) }}
</section>
{% endblock %}
