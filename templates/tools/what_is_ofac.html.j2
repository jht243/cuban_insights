      tag="ofac-actions",
      notes="Signed up from What Is OFAC explainer"
  ) }}

  {% from "_cluster_nav.html.j2" import cluster_nav %}
  {{ cluster_nav(cluster_ctx) }}

</section>
{% endblock %}
