{% extends "_base.html.j2" %}

{% block head_extra %}
<style>
  .tool-intro { background: var(--sr-gray-bg); border-left: 4px solid var(--sr-blue); padding: 18px 22px; margin: 16px 0 28px; }
  .tool-intro h2 { margin: 0 0 6px; font-family: var(--font-serif); color: var(--sr-blue-dark); font-size: 18px; }
  .tool-intro p { margin: 0; font-size: 14px; color: var(--sr-dark-text); }
  .gl-chips { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; margin: 12px 0 6px; }
  .gl-chips .label { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--sr-gray-text); font-weight: 600; margin-right: 2px; }
  .gl-chips a { display: inline-block; padding: 4px 10px; border: 1px solid var(--sr-gray-light); border-radius: 999px; background: #f7f9fc; color: var(--sr-blue-dark); text-decoration: none; font-size: 12px; font-weight: 500; transition: all 0.15s; }
  .gl-chips a:hover, .gl-chips a.active { background: var(--sr-blue); color: var(--white); border-color: var(--sr-blue); }
  .gl-search { display: flex; gap: 8px; margin: 8px 0 16px; flex-wrap: wrap; }
  .gl-search input { flex:1 1 240px; padding: 10px 14px; border: 1px solid var(--sr-gray-light); border-radius: 3px; font-size: 14px; }
  .gl-search select { padding: 10px 14px; border: 1px solid var(--sr-gray-light); border-radius: 3px; font-size: 14px; background: var(--white); }
  .gl-search .btn-clear { background: var(--white); color: var(--sr-gray-text); border: 1px solid var(--sr-gray-light); padding: 9px 14px; font-size: 13px; font-weight: 500; cursor: pointer; border-radius: 3px; }
  .gl-search .btn-clear:hover { background: #f7f9fc; color: var(--sr-blue-dark); border-color: var(--sr-blue); }
  .gl-search .btn-clear:disabled { opacity: 0.45; cursor: default; }
  .gl-empty { background: #eef2f7; border-left: 4px solid var(--sr-gray-text); padding: 14px 18px; font-size: 14px; color: var(--sr-dark-text); border-radius: 3px; margin: 8px 0 16px; display: none; }
  .gl-empty.show { display: block; }
  .gl-card { border: 1px solid var(--sr-gray-light); border-left: 4px solid var(--sr-blue); padding: 18px 22px; margin-bottom: 14px; border-radius: 3px; background: var(--white); }
  .gl-card.expired { border-left-color: var(--sr-red); }
  .gl-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; flex-wrap: wrap; }
  .gl-num { background: var(--sr-blue); color: var(--white); font-family: var(--font-serif); padding: 6px 12px; border-radius: 3px; font-weight: 700; font-size: 14px; letter-spacing: 0.4px; }
  .gl-card h3 { font-family: var(--font-serif); color: var(--sr-blue-dark); font-size: 17px; margin: 8px 0 6px; }
  .gl-card .summary { font-size: 14px; color: var(--sr-dark-text); margin-bottom: 8px; }
  .gl-card .ctx { font-size: 13px; color: var(--sr-gray-text); font-style: italic; padding: 8px 10px; background: var(--sr-gray-bg); border-left: 3px solid var(--sr-gray-light); margin: 8px 0; }
  .gl-meta { font-size: 12px; color: var(--sr-gray-text); margin-top: 8px; }
  .gl-meta strong { color: var(--sr-blue-dark); }
  .gl-tag { display: inline-block; padding: 2px 8px; background: var(--sr-gray-light); color: var(--sr-dark-text); border-radius: 10px; font-size: 11px; margin-right: 4px; }
  .gl-empty { text-align: center; padding: 32px; color: var(--sr-gray-text); }
  .disclaimer { background: #fff3e0; border-left: 4px solid #f5b041; padding: 14px 18px; font-size: 13px; color: #7c4a03; margin: 32px 0; border-radius: 3px; }
</style>
{% endblock %}

{% block content %}
<section class="container">

  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>/</span>
    <a href="/invest-in-cuba">Invest in Cuba</a><span>/</span>
    <span>OFAC General License Lookup</span>
  </nav>

  <header style="margin: 16px 0 20px;">
    <div style="font-size:12px; text-transform:uppercase; letter-spacing:1.4px; color:#cc0000; font-weight:700;">
      Compliance tool · Updated when OFAC publishes
    </div>
    <h1 style="font-family:var(--font-serif); font-size:32px; color:var(--sr-blue-dark); margin:8px 0 10px;">
      OFAC Cuba General License Lookup (CACR §515.560–.578)
    </h1>
    <p style="font-family:var(--font-serif); font-style:italic; color:var(--sr-gray-text); font-size:17px;">
      Searchable reference for every active CACR general license &mdash; the 12 travel categories, plus telecom, remittances, financial services, and informational materials.
    </p>
  </header>

  <details class="show-more">
    <summary><span class="label-closed">What is an OFAC general license, and which one do I need?</span><span class="label-open">Hide</span></summary>
    <div class="show-more__body">
      An OFAC general license pre-authorises specific transaction categories that would otherwise be prohibited by US sanctions, so each party doesn&rsquo;t have to apply individually. For Cuba, they live in 31 CFR Part 515 itself &mdash; mostly at §§515.560–515.578, which set out the 12 permitted travel categories. The most-used by US business travellers is <strong>§515.574 &ldquo;Support for the Cuban People,&rdquo;</strong> which underpins most legitimate engagement with MIPYMES, paladares, and casas particulares. Always read the full CACR text before relying on a license.
    </div>
  </details>

  <div class="gl-chips" id="gl-chips" role="group" aria-label="Filter by scope">
    <span class="label">Common scopes:</span>
    <a href="#" data-scope="">All</a>
    <a href="#" data-scope="travel">Travel</a>
    <a href="#" data-scope="remittances">Remittances</a>
    <a href="#" data-scope="telecom">Telecom / internet</a>
    <a href="#" data-scope="financial">Financial services</a>
    <a href="#" data-scope="humanitarian">Humanitarian</a>
    <a href="#" data-scope="informational">Informational materials</a>
  </div>

  <div class="gl-search">
    <input type="text" id="gl-q" placeholder="Search by §, category, counterparty…" aria-label="Search">
    <select id="gl-scope" aria-label="Filter by scope">
      <option value="">All scopes</option>
      <option value="travel">Travel</option>
      <option value="remittances">Remittances</option>
      <option value="telecom">Telecom / internet</option>
      <option value="financial">Financial services</option>
      <option value="humanitarian">Humanitarian</option>
      <option value="informational">Informational materials</option>
    </select>
    <button type="button" id="gl-clear" class="btn-clear" aria-label="Clear filters">Clear</button>
  </div>

  <div class="gl-empty" id="gl-empty">No general licenses match those filters. <a href="#" id="gl-empty-clear">Clear filters</a>.</div>

  <div id="gl-list">
    {% for gl in licenses %}
    <article class="gl-card" data-num="{{ gl.number|lower }}" data-summary="{{ gl.summary|lower }}" data-scope="{{ gl.scope|join(' ') }}" data-context="{{ gl.context|lower }}">
      <div class="gl-head">
        <span class="gl-num">{{ gl.number }}</span>
        <a href="{{ gl.ofac_url }}" rel="nofollow noopener" target="_blank" style="font-size:13px;">Read at OFAC &rarr;</a>
      </div>
      <h3>{{ gl.title }}</h3>
      <p class="summary">{{ gl.summary }}</p>
      <p class="ctx">{{ gl.context }}</p>
      <div class="gl-meta">
        <strong>Status:</strong> {{ gl.expires }} ·
        <strong>Scope:</strong>
        {% for s in gl.scope %}<span class="gl-tag">{{ s }}</span>{% endfor %}
      </div>
    </article>
    {% endfor %}
  </div>

  <div class="disclaimer">
    <strong>Important:</strong> Navigation aid only. CACR provisions and the State Department CRL change with administrations &mdash; sometimes intra-week. Always confirm by reading the full 31 CFR Part 515 text linked in each card. Not legal advice.
  </div>

  <script>
    (function() {
      var cards = Array.prototype.slice.call(document.querySelectorAll('#gl-list .gl-card'));
      var q = document.getElementById('gl-q');
      var scope = document.getElementById('gl-scope');
      var chips = document.getElementById('gl-chips');
      var clearBtn = document.getElementById('gl-clear');
      var empty = document.getElementById('gl-empty');
      var emptyClear = document.getElementById('gl-empty-clear');

      function active() { return (q.value || '').trim() !== '' || scope.value !== ''; }

      function syncChips() {
        chips.querySelectorAll('a').forEach(function(a) {
          a.classList.toggle('active', (a.getAttribute('data-scope') || '') === scope.value);
        });
      }

      function apply() {
        var qs = (q.value || '').toLowerCase().trim();
        var sc = scope.value;
        var visible = 0;
        cards.forEach(function(c) {
          var matchQ = !qs || c.dataset.num.indexOf(qs) !== -1
            || c.dataset.summary.indexOf(qs) !== -1
            || c.dataset.context.indexOf(qs) !== -1;
          var matchS = !sc || c.dataset.scope.split(' ').indexOf(sc) !== -1;
          var show = matchQ && matchS;
          c.style.display = show ? '' : 'none';
          if (show) visible++;
        });
        empty.classList.toggle('show', visible === 0);
        clearBtn.disabled = !active();
        syncChips();
      }

      function clearAll() {
        q.value = '';
        scope.value = '';
        apply();
        q.focus();
      }

      q.addEventListener('input', apply);
      scope.addEventListener('change', apply);
      clearBtn.addEventListener('click', clearAll);
      emptyClear.addEventListener('click', function(e) { e.preventDefault(); clearAll(); });
      chips.addEventListener('click', function(e) {
        var a = e.target.closest('a');
        if (!a) return;
        e.preventDefault();
        scope.value = a.getAttribute('data-scope') || '';
        apply();
      });
      apply();
    })();
  </script>

  {% from "_related_tools.html.j2" import related_tools_nav %}
  {{ related_tools_nav(related_tools_ctx) }}

  {% from "_cluster_nav.html.j2" import cluster_nav %}
  {{ cluster_nav(cluster_ctx) }}

</section>
{% endblock %}
