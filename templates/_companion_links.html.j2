{#
  Companion-links callout — a small, prominent block surfaced on hub
  pages (/tools, /sanctions-tracker, /companies) to push crawl equity
  and human attention to the deep tool / sister-hub pages those hubs
  should be cross-linking to.

  Differs from `_cluster_nav.html.j2` in two ways:
    1. Curated per-call list of target paths (not topology-derived) —
       lets each hub surface a different set of next-step destinations.
    2. Rendered ABOVE the fold near the page header, not at the page
       bottom. Hub pages are crawl-equity distributors; we don't want
       Googlebot or readers to have to scroll past a 500-row table
       before finding the next-click links.

  Inputs (passed as a dict via `companion_ctx`):
      companion_ctx.eyebrow = short uppercase label (e.g. "Tools that use this data")
      companion_ctx.title   = optional H3 heading (omit for compact mode)
      companion_ctx.links   = list[ClusterLink] from companion_links()
#}
{% macro companion_links(ctx) -%}
{% if ctx and ctx.links %}
<aside class="companion-links" aria-labelledby="companion-links-title">
  <header class="companion-links__head">
    {% if ctx.eyebrow %}
    <p class="companion-links__eyebrow">{{ ctx.eyebrow }}</p>
    {% endif %}
    {% if ctx.title %}
    <h2 id="companion-links-title" class="companion-links__title">{{ ctx.title }}</h2>
    {% endif %}
  </header>
  <ul class="companion-links__list">
    {% for link in ctx.links %}
    <li>
      <a href="{{ link.path }}">{{ link.anchor }}</a>
    </li>
    {% endfor %}
  </ul>
</aside>
{% endif %}
{%- endmacro %}

{% macro companion_links_css() -%}
<style>
  .companion-links {
    margin: 24px 0 28px;
    padding: 16px 18px;
    background: #f7f9fb;
    border: 1px solid #e6ebf2;
    border-left: 3px solid #002b5e;
    border-radius: 4px;
  }
  .companion-links__head { margin: 0 0 10px; }
  .companion-links__eyebrow {
    font-family: 'Open Sans', sans-serif;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.4px;
    color: #cc0000;
    font-weight: 700;
    margin: 0 0 4px;
  }
  .companion-links__title {
    font-family: 'Libre Baskerville', serif;
    font-size: 18px;
    color: #001f44;
    margin: 0;
    line-height: 1.3;
  }
  .companion-links__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 6px 18px;
  }
  .companion-links__list li {
    margin: 0;
    padding: 4px 0;
    line-height: 1.45;
    font-size: 14px;
  }
  .companion-links__list a {
    color: #002b5e;
    text-decoration: none;
    font-weight: 600;
    border-bottom: 1px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }
  .companion-links__list a:hover {
    color: #cc0000;
    border-bottom-color: #cc0000;
  }
</style>
{%- endmacro %}
