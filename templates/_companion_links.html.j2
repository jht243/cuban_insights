{#
  Companion-links callout — a curated block surfaced on hub pages
  (/tools, /sanctions-tracker, /companies) to push crawl equity
  and human attention to related tool / sister-hub pages.

  Inputs (passed as a dict via `companion_ctx`):
      companion_ctx.eyebrow = short uppercase label
      companion_ctx.title   = optional heading (omit for compact mode)
      companion_ctx.links   = list[ClusterLink] with path, anchor, description
#}
{% macro companion_links(ctx) -%}
{% if ctx and ctx.links %}
<aside class="companion-links" aria-labelledby="companion-links-title">
  <header class="companion-links__head">
    {% if ctx.eyebrow %}
    <p class="companion-links__eyebrow">{{ ctx.eyebrow }}</p>
    {% endif %}
    {% if ctx.title %}
    <h2 id="companion-links-title" class="companion-links__title">{{ ctx.title }}</h2>
    {% endif %}
  </header>
  <div class="companion-links__grid">
    {% for link in ctx.links %}
    <a class="companion-links__card" href="{{ link.path }}">
      <span class="companion-links__card-name">{{ link.anchor }}</span>
      {% if link.description %}
      <span class="companion-links__card-desc">{{ link.description }}</span>
      {% endif %}
    </a>
    {% endfor %}
  </div>
</aside>
{% endif %}
{%- endmacro %}

{% macro companion_links_css() -%}
<style>
  .companion-links {
    margin: 24px 0 28px;
    padding: 18px 20px;
    background: #f7f9fb;
    border: 1px solid #e6ebf2;
    border-radius: 6px;
  }
  .companion-links__head { margin: 0 0 14px; }
  .companion-links__eyebrow {
    font-family: 'Open Sans', sans-serif;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.4px;
    color: var(--sr-gray-text, #6b7280);
    font-weight: 700;
    margin: 0 0 4px;
  }
  .companion-links__title {
    font-family: 'Libre Baskerville', serif;
    font-size: 17px;
    color: #001f44;
    margin: 0;
    line-height: 1.3;
  }
  .companion-links__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 10px;
  }
  .companion-links__card {
    display: flex;
    flex-direction: column;
    padding: 12px 14px;
    background: #fff;
    border: 1px solid #e6ebf2;
    border-radius: 5px;
    text-decoration: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .companion-links__card:hover {
    border-color: #002b5e;
    box-shadow: 0 2px 8px rgba(0, 43, 94, 0.08);
  }
  .companion-links__card-name {
    font-size: 14px;
    font-weight: 600;
    color: #002b5e;
    line-height: 1.35;
  }
  .companion-links__card:hover .companion-links__card-name {
    color: #cc0000;
  }
  .companion-links__card-desc {
    font-size: 12.5px;
    color: #6b7280;
    line-height: 1.4;
    margin-top: 4px;
  }
</style>
{%- endmacro %}
