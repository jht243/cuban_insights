{#
  "Other tools" strip — rendered at the bottom of every tool page,
  above the topic-cluster nav. Always 3 curated sibling tools so the
  reader has an obvious next utility to try.

  This is intentionally separate from the cluster nav. Cluster nav
  surfaces topical content (explainers, sector pages, hub pages).
  This one surfaces other interactive tools — different reading
  intent ("I want to do another lookup") deserves its own affordance.

  Inputs (passed via Jinja `related_tools_ctx` dict):
      related_tools_ctx.tools = list[dict]
          Each item: { path, name, tagline }
          Empty list => macro renders nothing.

  NOTE: the dict key is `tools`, not `items` — Jinja attribute lookup
  resolves `.items` to the dict's built-in method first.
#}
{% macro related_tools_nav(ctx) -%}
{% if ctx and ctx.tools %}
<aside class="other-tools" aria-labelledby="other-tools-title">
  <header class="other-tools__head">
    <h2 id="other-tools-title" class="other-tools__title">Related tools</h2>
    <p class="other-tools__count">{{ ctx.tools|length }} related tool{{ '' if ctx.tools|length == 1 else 's' }}</p>
  </header>
  <ul class="other-tools__grid">
    {% for tool in ctx.tools %}
    <li>
      <a href="{{ tool.path }}" class="other-tools__card">
        <span class="other-tools__card-eyebrow"><span aria-hidden="true"></span> Related tool</span>
        <span class="other-tools__card-name">{{ tool.name }}</span>
        <span class="other-tools__card-tagline">{{ tool.tagline }}</span>
        <span class="other-tools__card-cta" aria-hidden="true">Open page &rarr;</span>
      </a>
    </li>
    {% endfor %}
  </ul>
</aside>
{% endif %}
{%- endmacro %}

{#
  Inline CSS — included once at the top of _base.html.j2 so every page
  inherits styles even if a specific template forgets the import.
#}
{% macro related_tools_nav_css() -%}
<style>
  .other-tools {
    margin: 64px 0 28px;
    padding: 0;
    background: transparent;
    border: 0;
  }
  .other-tools__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 18px;
    margin-bottom: 28px;
    padding-bottom: 18px;
    border-bottom: 1px solid #d6dde6;
  }
  .other-tools__title {
    font-family: 'Libre Baskerville', serif;
    font-size: 32px;
    color: #001f44;
    margin: 0;
    line-height: 1.2;
  }
  .other-tools__count {
    margin: 0;
    color: #6c757d;
    font-size: 20px;
    white-space: nowrap;
  }
  .other-tools__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
  }
  .other-tools__grid li { margin: 0; }
  .other-tools__card {
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 270px;
    padding: 28px 30px;
    background: #ffffff;
    border: 1px solid #d6dde6;
    border-radius: 6px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
  }
  .other-tools__card:hover {
    border-color: #002b5e;
    box-shadow: 0 12px 28px rgba(0, 31, 68, 0.08);
    transform: translateY(-1px);
  }
  .other-tools__card-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
    font-family: 'Open Sans', sans-serif;
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 2px;
    line-height: 1;
    text-transform: uppercase;
    color: #c7251a;
  }
  .other-tools__card-eyebrow span {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #c7251a;
    flex: 0 0 auto;
  }
  .other-tools__card-name {
    font-family: 'Libre Baskerville', serif;
    font-size: 22px;
    font-weight: 700;
    color: #111827;
    line-height: 1.15;
  }
  .other-tools__card:hover .other-tools__card-name { color: #cc0000; }
  .other-tools__card-tagline {
    font-size: 16px;
    color: #374151;
    margin-top: 18px;
    line-height: 1.55;
    flex-grow: 1;
  }
  .other-tools__card-cta {
    font-size: 17px;
    font-weight: 800;
    line-height: 1.2;
    color: #002b5e;
    margin-top: auto;
    padding-top: 26px;
  }
  @media (max-width: 980px) {
    .other-tools__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 720px) {
    .other-tools__head {
      display: block;
      margin-bottom: 20px;
    }
    .other-tools__title {
      font-size: 26px;
    }
    .other-tools__count {
      margin-top: 6px;
      font-size: 15px;
    }
    .other-tools__grid { grid-template-columns: 1fr; }
    .other-tools__card {
      min-height: 0;
      padding: 26px 28px;
    }
    .other-tools__card-name {
      font-size: 23px;
    }
    .other-tools__card-tagline {
      font-size: 16px;
      margin-top: 16px;
    }
    .other-tools__card-cta {
      padding-top: 24px;
      font-size: 16px;
    }
  }
</style>
{%- endmacro %}
