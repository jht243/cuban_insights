{#
  Cluster navigation block — the "what to read next" module rendered at
  the bottom of every cluster page. Designed for human navigation
  first, SEO second.

  UX rules baked into this layout:
    1. Show at most 3 sibling pages — anything more becomes a "site
       map dump" that overwhelms the reader. The full mesh lives on
       the pillar page; we link to it via "See N more in this hub →".
    2. Pillar is the single visually-loud element so the reader has an
       obvious "next click for context" path. Siblings are quiet
       supporting cards.
    3. No marketing-paragraph cluster summary in the nav. The summary
       belongs on the pillar page itself; in the nav it's just noise
       between the title and the actionable links.
    4. Short, conversational headings ("Keep reading" / "More in this
       hub") instead of taxonomy labels ("Topic cluster: ...").

  SEO rules still respected:
    • Pillar always linked with its canonical anchor.
    • Each visible sibling links with its canonical anchor.
    • Hidden siblings remain crawlable from the pillar page (which is
      itself the canonical hub index for the cluster) — Google still
      sees the full mesh through one extra hop.

  Inputs (passed via Jinja `cluster_ctx` dict on every render):
      cluster_ctx.cluster        = Cluster instance (or None to skip render)
      cluster_ctx.pillar         = ClusterLink to pillar (None when current page IS the pillar)
      cluster_ctx.others         = list[ClusterLink], capped at 3 by build_cluster_ctx
      cluster_ctx.is_pillar      = bool — current page IS the pillar
      cluster_ctx.total_members  = total number of sibling pages in the cluster
      cluster_ctx.hidden_count   = how many siblings are NOT in `others` (drives "See N more →")
#}
{% macro cluster_nav(cluster_ctx) -%}
{% if cluster_ctx and cluster_ctx.cluster %}
<aside class="cluster-nav" aria-labelledby="cluster-nav-title">
  <header class="cluster-nav__head">
    <h2 id="cluster-nav-title" class="cluster-nav__title">More in {{ cluster_ctx.cluster.name }}</h2>
    <p class="cluster-nav__count">{{ cluster_ctx.total_members }} related page{{ '' if cluster_ctx.total_members == 1 else 's' }}</p>
  </header>

  {% if cluster_ctx.others %}
  <ol class="cluster-nav__related">
    {% for link in cluster_ctx.others %}
    <li>
      <a href="{{ link.path }}">
        <span class="cluster-nav__related-eyebrow"><span aria-hidden="true"></span> In this hub</span>
        <span class="cluster-nav__related-anchor">{{ link.anchor }}</span>
        {% if link.description %}
        <span class="cluster-nav__related-desc">{{ link.description }}</span>
        {% endif %}
        <span class="cluster-nav__related-cta" aria-hidden="true">Open page &rarr;</span>
      </a>
    </li>
    {% endfor %}
  </ol>
  {% endif %}

  {% if cluster_ctx.pillar %}
  <p class="cluster-nav__more">
    <a href="{{ cluster_ctx.pillar.path }}">View hub &mdash; {{ cluster_ctx.cluster.name }}</a>
  </p>
  {% endif %}
</aside>
{% endif %}
{%- endmacro %}

{#
  Inline CSS — kept inside the macro file so any template that imports
  the macro inherits the styles via {% include %} of the CSS partial
  below. Templates extending _base.html.j2 already include this in
  {% block head_extra %}.
#}
{% macro cluster_nav_css() -%}
<style>
  .cluster-nav {
    margin: 64px 0 28px;
    padding: 0;
    background: transparent;
    border: 0;
  }
  .cluster-nav__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 18px;
    margin-bottom: 28px;
    padding-bottom: 18px;
    border-bottom: 1px solid #d6dde6;
  }
  .cluster-nav__title {
    font-family: 'Libre Baskerville', serif;
    font-size: 32px;
    color: #001f44;
    margin: 0;
    line-height: 1.2;
  }
  .cluster-nav__count {
    margin: 0;
    color: #6c757d;
    font-size: 20px;
    white-space: nowrap;
  }
  .cluster-nav__related {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
  }
  .cluster-nav__related li { margin: 0; }
  .cluster-nav__related a {
    display: flex;
    flex-direction: column;
    height: 100%;
    min-height: 270px;
    padding: 28px 30px;
    background: #ffffff;
    border: 1px solid #d6dde6;
    border-radius: 6px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
  }
  .cluster-nav__related a:hover {
    border-color: #002b5e;
    box-shadow: 0 12px 28px rgba(0, 31, 68, 0.08);
    transform: translateY(-1px);
  }
  .cluster-nav__related-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
    font-family: 'Open Sans', sans-serif;
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 2px;
    line-height: 1;
    text-transform: uppercase;
    color: #c7251a;
  }
  .cluster-nav__related-eyebrow span {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #c7251a;
    flex: 0 0 auto;
  }
  .cluster-nav__related-anchor {
    display: block;
    font-family: 'Libre Baskerville', serif;
    font-size: 22px;
    font-weight: 700;
    color: #111827;
    line-height: 1.15;
  }
  .cluster-nav__related a:hover .cluster-nav__related-anchor { color: #cc0000; }
  .cluster-nav__related-desc {
    display: block;
    font-size: 16px;
    color: #374151;
    margin-top: 18px;
    line-height: 1.55;
  }
  .cluster-nav__related-cta {
    margin-top: auto;
    padding-top: 26px;
    font-size: 17px;
    line-height: 1.2;
    color: #002b5e;
    font-weight: 800;
  }
  .cluster-nav__more {
    margin: 32px 0 0;
    font-size: 20px;
  }
  .cluster-nav__more a {
    color: #002b5e;
    text-decoration: none;
    font-weight: 800;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s, color 0.15s;
  }
  .cluster-nav__more a:hover {
    color: #cc0000;
    border-bottom-color: #cc0000;
  }
  @media (max-width: 980px) {
    .cluster-nav__related {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 720px) {
    .cluster-nav__head {
      display: block;
      margin-bottom: 20px;
    }
    .cluster-nav__title {
      font-size: 26px;
    }
    .cluster-nav__count {
      margin-top: 6px;
      font-size: 15px;
    }
    .cluster-nav__related {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .cluster-nav__related a {
      min-height: 0;
      padding: 26px 28px;
    }
    .cluster-nav__related-anchor {
      font-size: 23px;
    }
    .cluster-nav__related-desc {
      font-size: 16px;
      margin-top: 16px;
    }
    .cluster-nav__related-cta {
      padding-top: 24px;
      font-size: 16px;
    }
  }
</style>
{%- endmacro %}
