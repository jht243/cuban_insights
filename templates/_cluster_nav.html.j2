{#
  Cluster navigation block — the "what to read next" module rendered at
  the bottom of every cluster page. Designed for human navigation
  first, SEO second.

  UX rules baked into this layout:
    1. Show at most 3 sibling pages — anything more becomes a "site
       map dump" that overwhelms the reader. The full mesh lives on
       the pillar page; we link to it via "See N more in this hub →".
    2. Pillar is the single visually-loud element so the reader has an
       obvious "next click for context" path. Siblings are quiet
       supporting cards.
    3. No marketing-paragraph cluster summary in the nav. The summary
       belongs on the pillar page itself; in the nav it's just noise
       between the title and the actionable links.
    4. Short, conversational headings ("Keep reading" / "More in this
       hub") instead of taxonomy labels ("Topic cluster: ...").

  SEO rules still respected:
    • Pillar always linked with its canonical anchor.
    • Each visible sibling links with its canonical anchor.
    • Hidden siblings remain crawlable from the pillar page (which is
      itself the canonical hub index for the cluster) — Google still
      sees the full mesh through one extra hop.

  Inputs (passed via Jinja `cluster_ctx` dict on every render):
      cluster_ctx.cluster        = Cluster instance (or None to skip render)
      cluster_ctx.pillar         = ClusterLink to pillar (None when current page IS the pillar)
      cluster_ctx.others         = list[ClusterLink], capped at 3 by build_cluster_ctx
      cluster_ctx.is_pillar      = bool — current page IS the pillar
      cluster_ctx.total_members  = total number of sibling pages in the cluster
      cluster_ctx.hidden_count   = how many siblings are NOT in `others` (drives "See N more →")
#}
{% macro cluster_nav(cluster_ctx) -%}
{% if cluster_ctx and cluster_ctx.cluster %}
<aside class="cluster-nav" aria-labelledby="cluster-nav-title">
  <header class="cluster-nav__head">
    <p class="cluster-nav__eyebrow">{% if cluster_ctx.is_pillar %}In this hub{% else %}Keep reading{% endif %}</p>
    <h2 id="cluster-nav-title" class="cluster-nav__title">{{ cluster_ctx.cluster.name }}</h2>
  </header>

  {% if cluster_ctx.pillar %}
  <a class="cluster-nav__pillar" href="{{ cluster_ctx.pillar.path }}">
    <span class="cluster-nav__pillar-eyebrow">Hub page</span>
    <span class="cluster-nav__pillar-anchor">{{ cluster_ctx.pillar.anchor }}</span>
    {% if cluster_ctx.pillar.description %}
    <span class="cluster-nav__pillar-desc">{{ cluster_ctx.pillar.description }}</span>
    {% endif %}
    <span class="cluster-nav__pillar-cta" aria-hidden="true">Open hub &rarr;</span>
  </a>
  {% endif %}

  {% if cluster_ctx.others %}
  <ol class="cluster-nav__related">
    {% for link in cluster_ctx.others %}
    <li>
      <a href="{{ link.path }}">
        <span class="cluster-nav__related-anchor">{{ link.anchor }}</span>
        {% if link.description %}
        <span class="cluster-nav__related-desc">{{ link.description }}</span>
        {% endif %}
      </a>
    </li>
    {% endfor %}
  </ol>
  {% endif %}

  {% if cluster_ctx.hidden_count and cluster_ctx.hidden_count > 0 and cluster_ctx.pillar %}
  <p class="cluster-nav__more">
    <a href="{{ cluster_ctx.pillar.path }}">See {{ cluster_ctx.hidden_count }} more page{{ '' if cluster_ctx.hidden_count == 1 else 's' }} in {{ cluster_ctx.cluster.name }} &rarr;</a>
  </p>
  {% endif %}
</aside>
{% endif %}
{%- endmacro %}

{#
  Inline CSS — kept inside the macro file so any template that imports
  the macro inherits the styles via {% include %} of the CSS partial
  below. Templates extending _base.html.j2 already include this in
  {% block head_extra %}.
#}
{% macro cluster_nav_css() -%}
<style>
  .cluster-nav {
    margin: 56px 0 24px;
    padding: 0;
    background: transparent;
    border: 0;
  }
  .cluster-nav__head {
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 1px solid #e9ecef;
  }
  .cluster-nav__eyebrow {
    font-family: 'Open Sans', sans-serif;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.4px;
    color: #cc0000;
    font-weight: 700;
    margin: 0 0 4px;
  }
  .cluster-nav__title {
    font-family: 'Libre Baskerville', serif;
    font-size: 22px;
    color: #001f44;
    margin: 0;
    line-height: 1.25;
  }
  .cluster-nav__pillar {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      "eyebrow  cta"
      "anchor   cta"
      "desc     cta";
    column-gap: 18px;
    align-items: center;
    background: #ffffff;
    border: 1px solid #d6dde6;
    border-left: 4px solid #cc0000;
    padding: 16px 20px;
    margin-bottom: 18px;
    text-decoration: none;
    color: inherit;
    border-radius: 4px;
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
  }
  .cluster-nav__pillar:hover {
    border-color: #002b5e;
    box-shadow: 0 2px 8px rgba(0, 31, 68, 0.08);
    transform: translateY(-1px);
  }
  .cluster-nav__pillar-eyebrow {
    grid-area: eyebrow;
    font-family: 'Open Sans', sans-serif;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1.4px;
    color: #cc0000;
    font-weight: 700;
  }
  .cluster-nav__pillar-anchor {
    grid-area: anchor;
    display: block;
    font-family: 'Libre Baskerville', serif;
    font-weight: 700;
    color: #001f44;
    font-size: 17px;
    line-height: 1.35;
    margin-top: 2px;
  }
  .cluster-nav__pillar-desc {
    grid-area: desc;
    display: block;
    font-size: 13px;
    color: #495057;
    margin-top: 4px;
    line-height: 1.5;
  }
  .cluster-nav__pillar-cta {
    grid-area: cta;
    align-self: center;
    font-family: 'Open Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #002b5e;
    white-space: nowrap;
  }
  .cluster-nav__related {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }
  .cluster-nav__related li { margin: 0; }
  .cluster-nav__related a {
    display: block;
    height: 100%;
    padding: 14px 16px;
    background: #f7f9fb;
    border: 1px solid #e6ebf2;
    border-radius: 4px;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s, border-color 0.15s, transform 0.15s;
  }
  .cluster-nav__related a:hover {
    background: #ffffff;
    border-color: #002b5e;
    transform: translateY(-1px);
  }
  .cluster-nav__related-anchor {
    display: block;
    font-family: 'Libre Baskerville', serif;
    font-size: 14.5px;
    font-weight: 700;
    color: #002b5e;
    line-height: 1.35;
  }
  .cluster-nav__related a:hover .cluster-nav__related-anchor { color: #cc0000; }
  .cluster-nav__related-desc {
    display: block;
    font-size: 12.5px;
    color: #6c757d;
    margin-top: 6px;
    line-height: 1.5;
  }
  .cluster-nav__more {
    margin: 14px 0 0;
    text-align: right;
    font-size: 13px;
  }
  .cluster-nav__more a {
    color: #002b5e;
    text-decoration: none;
    font-weight: 600;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s, color 0.15s;
  }
  .cluster-nav__more a:hover {
    color: #cc0000;
    border-bottom-color: #cc0000;
  }
  @media (max-width: 720px) {
    .cluster-nav__pillar {
      grid-template-columns: 1fr;
      grid-template-areas:
        "eyebrow"
        "anchor"
        "desc"
        "cta";
      row-gap: 4px;
    }
    .cluster-nav__pillar-cta { margin-top: 6px; }
    .cluster-nav__related {
      grid-template-columns: 1fr;
    }
  }
</style>
{%- endmacro %}
